<script>
(function () {

  // ---------- constants ----------
  const FONT_ROLES = [
    { key: 'display', label: 'Display', cssVar: '--serif-d', fallback: 'Georgia, serif' },
    { key: 'body',    label: 'Body',    cssVar: '--serif-b', fallback: 'Georgia, serif' },
    { key: 'sans',    label: 'Sans',    cssVar: '--sans',    fallback: 'system-ui, sans-serif' },
    { key: 'mono',    label: 'Mono',    cssVar: '--mono',    fallback: 'ui-monospace, monospace' }
  ];

  const SLOT_PRESETS = [
    { label: 'Square',           value: '1/1',   type: 'ratio'  },
    { label: 'Photo (4:3)',      value: '4/3',   type: 'ratio'  },
    { label: 'Widescreen (16:9)',value: '16/9',  type: 'ratio'  },
    { label: 'Cinema (21:9)',    value: '21/9',  type: 'ratio'  },
    { label: 'Tile (5:4)',       value: '5/4',   type: 'ratio'  },
    { label: 'Portrait (3:4)',   value: '3/4',   type: 'ratio'  },
    { label: 'Tower (2:3)',      value: '2/3',   type: 'ratio'  },
    { label: 'Tall (9:16)',      value: '9/16',  type: 'ratio'  },
    { label: 'Banner (5:1)',     value: '5/1',   type: 'ratio'  },
    { label: 'Hero (3:1)',       value: '3/1',   type: 'ratio'  },
    { label: 'Short (120px)',    value: '120px', type: 'height' },
    { label: 'Card (240px)',     value: '240px', type: 'height' },
    { label: 'Tall card (480px)',value: '480px', type: 'height' }
  ];

  const SECTION_SPOT_VARS = {
    accent:  '--sec',
    heading: '--sec-heading'
  };

  // ---------- state ----------
  const STATE_EL = document.getElementById('builder-state');
  let state, DEFAULTS;
  try {
    state = JSON.parse(STATE_EL.textContent);
    DEFAULTS = JSON.parse(JSON.stringify(state));
  } catch (e) {
    console.error('builder-state JSON is invalid:', e);
    return;
  }

  // ---------- helpers ----------
  function normHex(v) {
    if (!v) return null;
    v = v.trim().replace(/^#/, '');
    if (/^[0-9a-f]{3}$/i.test(v)) v = v.split('').map(c => c + c).join('');
    if (/^[0-9a-f]{6}$/i.test(v)) return '#' + v.toLowerCase();
    return null;
  }
  function hexToRgba(hex, a) {
    const v = hex.replace('#', '');
    const r = parseInt(v.substring(0, 2), 16);
    const g = parseInt(v.substring(2, 4), 16);
    const b = parseInt(v.substring(4, 6), 16);
    return `rgba(${r}, ${g}, ${b}, ${a})`;
  }
  function randomHex() {
    return '#' + Math.floor(Math.random() * 0xffffff).toString(16).padStart(6, '0');
  }
  function paletteCssVar(key)  { return '--c-' + key.slice(1); }
  function paletteTintVar(key) { return '--t-' + key.slice(1); }
  function updateSliderFill(slider) {
    const min = parseFloat(slider.min);
    const max = parseFloat(slider.max);
    const pct = ((parseFloat(slider.value) - min) / (max - min)) * 100;
    slider.style.setProperty('--fill', pct + '%');
  }

  function makeLockBtn(isLocked, onToggle) {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'editor-lock' + (isLocked ? ' is-locked' : '');
    btn.title = 'Lock this color (skip during Randomize)';
    btn.setAttribute('aria-label', 'Lock');
    btn.addEventListener('click', () => {
      const next = !btn.classList.contains('is-locked');
      btn.classList.toggle('is-locked', next);
      onToggle(next);
    });
    return btn;
  }

  // ---------- builders ----------
  function buildPaletteInputs() {
    const container = document.getElementById('editor-palette');
    container.innerHTML = '';
    for (let i = 1; i <= 10; i++) {
      const key = 'c' + i;
      const slot = state.palette[key];
      const cell = document.createElement('div');
      cell.className = 'editor-palette-cell';

      const swatch = document.createElement('div');
      swatch.className = 'swatch';
      cell.appendChild(swatch);

      if (!slot) {
        cell.classList.add('is-empty');
        container.appendChild(cell);
        continue;
      }

      swatch.style.setProperty('--swatch', slot.value);

      const label = document.createElement('div');
      label.className = 'label';
      label.textContent = slot.label || key;
      cell.appendChild(label);

      const controls = document.createElement('div');
      controls.className = 'controls';

      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'editor-input';
      input.value = slot.value;
      input.title = key;
      input.addEventListener('input', () => {
        const h = normHex(input.value);
        if (h) {
          applyPaletteColor(key, h);
          swatch.style.setProperty('--swatch', h);
        }
      });
      input.addEventListener('blur', () => { input.value = slot.value; });
      controls.appendChild(input);

      controls.appendChild(makeLockBtn(slot.locked, locked => { slot.locked = locked; }));
      cell.appendChild(controls);
      container.appendChild(cell);
    }
  }

  function buildSectionsPanel() {
    const wrap = document.getElementById('editor-sections');
    wrap.innerHTML = '';
    state.sections.forEach(sec => {
      const group = document.createElement('div');
      group.className = 'editor-section-group';
      const title = document.createElement('div');
      title.className = 'editor-section-group-title';
      title.textContent = sec.label;
      group.appendChild(title);
      Object.entries(sec.colors).forEach(([spotKey, spot]) => {
        const row = document.createElement('div');
        row.className = 'editor-section-spot';

        const swatch = document.createElement('div');
        swatch.className = 'swatch';
        swatch.style.setProperty('--swatch', spot.value);
        row.appendChild(swatch);

        const lbl = document.createElement('span');
        lbl.className = 'spot-label';
        lbl.textContent = spotKey;
        row.appendChild(lbl);

        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'editor-input';
        input.value = spot.value;
        input.addEventListener('input', () => {
          const h = normHex(input.value);
          if (h) {
            applySectionSpot(sec, spotKey, h);
            swatch.style.setProperty('--swatch', h);
          }
        });
        input.addEventListener('blur', () => { input.value = spot.value; });
        row.appendChild(input);

        row.appendChild(makeLockBtn(spot.locked, locked => { spot.locked = locked; }));
        group.appendChild(row);
      });
      wrap.appendChild(group);
    });
  }

  function buildSlots() {
    const wrap = document.getElementById('editor-slots');
    wrap.innerHTML = '';
    state.slots.forEach(slot => {
      const row = document.createElement('div');
      row.className = 'editor-slot-row';
      const lbl = document.createElement('span');
      lbl.className = 'label';
      lbl.textContent = slot.purpose;
      lbl.title = slot.purpose;
      const sel = document.createElement('select');
      sel.className = 'editor-select';
      const el = document.querySelector(`[data-slot="${slot.id}"]`);
      const currentAR = el ? el.style.aspectRatio : '';
      const currentMH = el ? el.style.minHeight : '';
      SLOT_PRESETS.forEach((preset, idx) => {
        const opt = document.createElement('option');
        opt.value = String(idx);
        opt.textContent = preset.label;
        if (preset.type === 'ratio'  && preset.value === currentAR) opt.selected = true;
        if (preset.type === 'height' && preset.value === currentMH) opt.selected = true;
        sel.appendChild(opt);
      });
      sel.addEventListener('change', () => {
        applySlotPreset(slot.id, SLOT_PRESETS[parseInt(sel.value, 10)]);
      });
      row.appendChild(lbl);
      row.appendChild(sel);
      wrap.appendChild(row);
    });
  }

  function buildFontPickers() {
    const wrap = document.getElementById('editor-fonts');
    wrap.innerHTML = '';
    FONT_ROLES.forEach(role => {
      const row = document.createElement('div');
      row.className = 'editor-label-row';
      const lbl = document.createElement('span');
      lbl.className = 'editor-label';
      lbl.textContent = role.label;
      const sel = document.createElement('select');
      sel.className = 'editor-select';
      sel.dataset.role = role.key;
      const current = state.fonts[role.key].family;
      const list = (state.fonts.available && state.fonts.available[role.key]) || [];
      if (!list.find(f => f.name === current)) {
        const o = document.createElement('option');
        o.value = current; o.textContent = current; o.selected = true;
        sel.appendChild(o);
      }
      list.forEach(f => {
        const o = document.createElement('option');
        o.value = f.name; o.textContent = f.name;
        if (f.name === current) o.selected = true;
        sel.appendChild(o);
      });
      sel.addEventListener('change', () => {
        const entry = list.find(f => f.name === sel.value);
        if (entry) applyFont(role, entry);
      });
      row.appendChild(lbl);
      row.appendChild(sel);
      wrap.appendChild(row);
    });
  }

  // ---------- behaviors ----------
  function applyPaletteColor(key, hex) {
    document.documentElement.style.setProperty(paletteCssVar(key), hex);
    document.documentElement.style.setProperty(paletteTintVar(key), hexToRgba(hex, state.tintAlpha));
    state.palette[key].value = hex;
  }

  function applyTintAlpha(alpha) {
    state.tintAlpha = alpha;
    document.documentElement.style.setProperty('--tint-alpha', alpha);
    Object.entries(state.palette).forEach(([key, slot]) => {
      document.documentElement.style.setProperty(paletteTintVar(key), hexToRgba(slot.value, alpha));
    });
  }

  function applySectionSpot(sec, spotKey, hex) {
    sec.colors[spotKey].value = hex;
    const el = document.querySelector(`[data-section="${sec.id}"]`);
    if (el) el.style.setProperty(SECTION_SPOT_VARS[spotKey], hex);
  }

  function applySlotPreset(id, preset) {
    const el = document.querySelector(`[data-slot="${id}"]`);
    if (!el) return;
    if (preset.type === 'ratio') {
      el.style.aspectRatio = preset.value;
      el.style.minHeight = '';
    } else {
      el.style.minHeight = preset.value;
      el.style.aspectRatio = '';
    }
  }

  function applyFont(role, entry) {
    let styleEl = document.getElementById('editor-font-' + role.key);
    if (!styleEl) {
      styleEl = document.createElement('style');
      styleEl.id = 'editor-font-' + role.key;
      document.head.appendChild(styleEl);
    }
    const faces = (entry.files || []).map(f => `
      @font-face {
        font-family: '${entry.name}';
        src: url('${f.url}') format('truetype');
        font-weight: ${f.weight || 400};
        font-style: ${f.style || 'normal'};
        font-display: swap;
      }
    `).join('\n');
    styleEl.textContent = faces;
    document.documentElement.style.setProperty(role.cssVar, `'${entry.name}', ${role.fallback}`);
    state.fonts[role.key] = { family: entry.name, source: 'repo' };
  }

  function bindRhythm() {
    const v = document.getElementById('editor-rhythm-v');
    const p = document.getElementById('editor-rhythm-p');
    const h = document.getElementById('editor-rhythm-h');

    v.addEventListener('input', () => {
      document.documentElement.style.setProperty('--rhythm', v.value);
      state.rhythm.vertical = parseFloat(v.value);
      updateSliderFill(v);
    });
    // Padding slider — flipped so right thumb = LESS padding (more content visible)
    p.addEventListener('input', () => {
      const flipped = (parseFloat(p.min) + parseFloat(p.max)) - parseFloat(p.value);
      document.documentElement.style.setProperty('--pad-x', flipped + 'px');
      state.rhythm.padX = flipped + 'px';
      updateSliderFill(p);
    });
    h.addEventListener('input', () => {
      document.documentElement.style.setProperty('--headline-scale', h.value);
      state.rhythm.headlineScale = parseFloat(h.value);
      updateSliderFill(h);
    });

    [v, p, h].forEach(updateSliderFill);
  }

  function bindTintAlpha() {
    const slider = document.getElementById('editor-tint-alpha');
    slider.addEventListener('input', () => {
      applyTintAlpha(parseFloat(slider.value) / 100);
      updateSliderFill(slider);
    });
    updateSliderFill(slider);
  }

  function bindEffects() {
    const sa = document.getElementById('editor-shadow-alpha');
    const sb = document.getElementById('editor-shadow-blur');
    const sh = document.getElementById('editor-shine');
    const pa = document.getElementById('editor-slot-alpha');
    const bg = document.getElementById('editor-bg-pattern');

    sa.addEventListener('input', () => {
      const v = parseFloat(sa.value) / 100;
      document.documentElement.style.setProperty('--shadow-alpha', v);
      state.effects.shadowAlpha = v;
      updateSliderFill(sa);
    });
    sb.addEventListener('input', () => {
      const v = sb.value + 'px';
      document.documentElement.style.setProperty('--shadow-blur', v);
      state.effects.shadowBlur = v;
      updateSliderFill(sb);
    });
    sh.addEventListener('input', () => {
      const v = parseFloat(sh.value) / 100;
      document.documentElement.style.setProperty('--shine-alpha', v);
      state.effects.shineAlpha = v;
      updateSliderFill(sh);
    });
    pa.addEventListener('input', () => {
      const v = parseFloat(pa.value) / 100;
      document.documentElement.style.setProperty('--slot-alpha', v);
      state.effects.slotAlpha = v;
      updateSliderFill(pa);
    });
    bg.addEventListener('input', () => {
      const v = parseFloat(bg.value) / 100;
      document.documentElement.style.setProperty('--bg-pattern-alpha', v);
      state.effects.bgPatternAlpha = v;
      updateSliderFill(bg);
    });

    [sa, sb, sh, pa, bg].forEach(updateSliderFill);
  }

  function randomizeAll() {
    Object.entries(state.palette).forEach(([key, slot]) => {
      if (!slot.locked) applyPaletteColor(key, randomHex());
    });
    state.sections.forEach(sec => {
      Object.entries(sec.colors).forEach(([spotKey, spot]) => {
        if (!spot.locked) applySectionSpot(sec, spotKey, randomHex());
      });
    });
    buildPaletteInputs();
    buildSectionsPanel();
  }

  function exportHtml() {
    const doc = document.documentElement.cloneNode(true);
    doc.querySelector('#editor-overlay')?.classList.remove('open');
    doc.querySelector('#editor-panel')?.classList.remove('open');

    const styleBlock = doc.querySelector('style');
    if (styleBlock) {
      let css = styleBlock.textContent;
      Object.entries(state.palette).forEach(([key, slot]) => {
        const cVar = paletteCssVar(key);
        css = css.replace(new RegExp('(' + cVar + ':\\s*)#[0-9a-fA-F]{3,6}', 'g'), '$1' + slot.value);
        const tVar = paletteTintVar(key);
        css = css.replace(new RegExp('(' + tVar + ':\\s*)rgba\\([^)]*\\)', 'g'), '$1' + hexToRgba(slot.value, state.tintAlpha));
      });
      styleBlock.textContent = css;
    }

    state.sections.forEach(sec => {
      const el = doc.querySelector(`[data-section="${sec.id}"]`);
      if (!el) return;
      Object.entries(sec.colors).forEach(([spotKey, spot]) => {
        el.style.setProperty(SECTION_SPOT_VARS[spotKey], spot.value);
      });
    });

    const stateScript = doc.querySelector('#builder-state');
    if (stateScript) stateScript.textContent = JSON.stringify(state, null, 2);

    const blob = new Blob(['<!DOCTYPE html>\n' + doc.outerHTML], { type: 'text/html' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = state.page.filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function copyCss() {
    const lines = [':root {'];
    Object.entries(state.palette).forEach(([k, slot]) => {
      lines.push(`  ${paletteCssVar(k)}: ${slot.value};`);
    });
    Object.entries(state.palette).forEach(([k, slot]) => {
      lines.push(`  ${paletteTintVar(k)}: ${hexToRgba(slot.value, state.tintAlpha)};`);
    });
    lines.push(`  --pad-x: ${state.rhythm.padX};`);
    lines.push(`  --rhythm: ${state.rhythm.vertical};`);
    lines.push(`  --headline-scale: ${state.rhythm.headlineScale};`);
    lines.push(`  --tint-alpha: ${state.tintAlpha};`);
    lines.push(`  --shadow-alpha: ${state.effects.shadowAlpha};`);
    lines.push(`  --shadow-blur: ${state.effects.shadowBlur};`);
    lines.push(`  --shine-alpha: ${state.effects.shineAlpha};`);
    lines.push(`  --slot-alpha: ${state.effects.slotAlpha};`);
    lines.push(`  --bg-pattern-alpha: ${state.effects.bgPatternAlpha};`);
    lines.push('}');
    navigator.clipboard.writeText(lines.join('\n')).catch(() => {});
  }

  function resetAll() {
    Object.entries(DEFAULTS.palette).forEach(([k, slot]) => {
      state.palette[k] = JSON.parse(JSON.stringify(slot));
      document.documentElement.style.setProperty(paletteCssVar(k), slot.value);
      document.documentElement.style.setProperty(paletteTintVar(k), hexToRgba(slot.value, DEFAULTS.tintAlpha));
    });
    state.tintAlpha = DEFAULTS.tintAlpha;
    document.documentElement.style.setProperty('--tint-alpha', state.tintAlpha);
    document.getElementById('editor-tint-alpha').value = Math.round(state.tintAlpha * 100);

    state.effects = JSON.parse(JSON.stringify(DEFAULTS.effects));
    document.documentElement.style.setProperty('--shadow-alpha',     state.effects.shadowAlpha);
    document.documentElement.style.setProperty('--shadow-blur',      state.effects.shadowBlur);
    document.documentElement.style.setProperty('--shine-alpha',      state.effects.shineAlpha);
    document.documentElement.style.setProperty('--slot-alpha',       state.effects.slotAlpha);
    document.documentElement.style.setProperty('--bg-pattern-alpha', state.effects.bgPatternAlpha);
    document.getElementById('editor-shadow-alpha').value = Math.round(state.effects.shadowAlpha * 100);
    document.getElementById('editor-shadow-blur').value  = parseFloat(state.effects.shadowBlur);
    document.getElementById('editor-shine').value        = Math.round(state.effects.shineAlpha * 100);
    document.getElementById('editor-slot-alpha').value   = Math.round(state.effects.slotAlpha * 100);
    document.getElementById('editor-bg-pattern').value   = Math.round(state.effects.bgPatternAlpha * 100);

    Object.assign(state.rhythm, DEFAULTS.rhythm);
    document.documentElement.style.setProperty('--rhythm', state.rhythm.vertical);
    document.documentElement.style.setProperty('--pad-x', state.rhythm.padX);
    document.documentElement.style.setProperty('--headline-scale', state.rhythm.headlineScale);

    state.sections.forEach((sec, i) => {
      const defSec = DEFAULTS.sections[i];
      Object.entries(defSec.colors).forEach(([spotKey, defSpot]) => {
        sec.colors[spotKey] = JSON.parse(JSON.stringify(defSpot));
        applySectionSpot(sec, spotKey, defSpot.value);
      });
    });

    state.fonts = JSON.parse(JSON.stringify(DEFAULTS.fonts));
    FONT_ROLES.forEach(role => {
      document.documentElement.style.setProperty(role.cssVar,
        `'${state.fonts[role.key].family}', ${role.fallback}`);
      const injected = document.getElementById('editor-font-' + role.key);
      if (injected) injected.remove();
    });

    state.slots.forEach(slot => {
      const el = document.querySelector(`[data-slot="${slot.id}"]`);
      if (el) { el.style.aspectRatio = ''; el.style.minHeight = ''; }
    });

    buildPaletteInputs();
    buildSectionsPanel();
    buildSlots();
    buildFontPickers();
    document.querySelectorAll('.editor-slider').forEach(updateSliderFill);
  }

  // ---------- wiring ----------
  const trigger  = document.querySelector('.editor-trigger');
  const panel    = document.getElementById('editor-panel');
  const overlay  = document.getElementById('editor-overlay');
  const closeBtn = document.getElementById('editor-close');

  function openPanel()  { panel.classList.add('open');    overlay.classList.add('open'); }
  function closePanel() { panel.classList.remove('open'); overlay.classList.remove('open'); }

  trigger.addEventListener('click', openPanel);
  closeBtn.addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closePanel(); });

  buildPaletteInputs();
  buildSectionsPanel();
  buildSlots();
  buildFontPickers();
  bindRhythm();
  bindTintAlpha();
  bindEffects();

  document.getElementById('editor-randomize').addEventListener('click', randomizeAll);
  document.getElementById('editor-export').addEventListener('click', exportHtml);
  document.getElementById('editor-copy').addEventListener('click', copyCss);
  document.getElementById('editor-reset').addEventListener('click', resetAll);

})();
</script>

</body>
</html>
