<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mudlark popup — test page</title>
<meta name="description" content="A minimal page to exercise every popup feature.">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23131210'/%3E%3Ccircle cx='16' cy='16' r='6' fill='%23E8B23A'/%3E%3C/svg%3E">

<style>
/* ============================== FONTS (from the repo) ============================== */
@font-face {
  font-family: 'Fraunces';
  src: url('https://raw.githubusercontent.com/Mudlark-Media-Network/mudlarkmedia.github.io/main/Website/Style%20Guide/Fonts/Fraunces/Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  font-weight: 100 1000;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Fraunces';
  src: url('https://raw.githubusercontent.com/Mudlark-Media-Network/mudlarkmedia.github.io/main/Website/Style%20Guide/Fonts/Fraunces/Fraunces-Italic-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  font-weight: 100 1000;
  font-style: italic;
  font-display: swap;
}
@font-face {
  font-family: 'IBM Plex Sans';
  src: url('https://raw.githubusercontent.com/Mudlark-Media-Network/mudlarkmedia.github.io/main/Website/Style%20Guide/Fonts/IBM_Plex_Sans/IBMPlexSans-VariableFont_wdth,wght.ttf') format('truetype');
  font-weight: 100 900;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: 'Spline Sans Mono';
  src: url('https://raw.githubusercontent.com/Mudlark-Media-Network/mudlarkmedia.github.io/main/Website/Style%20Guide/Fonts/Spline_Sans_Mono/SplineSansMono-VariableFont_wght.ttf') format('truetype');
  font-weight: 300 700;
  font-style: normal;
  font-display: swap;
}

:root {
  /* PAGE PALETTE */
  --c-1:  #E8B23A;
  --c-2:  #DD5E2C;
  --c-3:  #2EA39C;
  --c-4:  #4F95CC;
  --c-5:  #CC6094;
  --c-6:  #131210;
  --c-7:  #1F1D19;
  --c-8:  #ECE5D2;
  --c-9:  #9C9583;
  --c-10: #3F3C33;

  --t-1: rgba(232, 178,  58, 0.07);
  --t-2: rgba(221,  94,  44, 0.07);
  --t-3: rgba( 46, 163, 156, 0.07);
  --t-4: rgba( 79, 149, 204, 0.07);
  --t-5: rgba(204,  96, 148, 0.07);
  --t-6: rgba( 19,  18,  16, 0.07);
  --t-7: rgba( 31,  29,  25, 0.07);
  --t-8: rgba(236, 229, 210, 0.07);
  --t-9: rgba(156, 149, 131, 0.07);
  --t-10: rgba( 63,  60,  51, 0.07);

  --bg:       var(--c-6);
  --bg-up:    var(--c-7);
  --ink:      var(--c-8);
  --ink-soft: var(--c-9);
  --rule:     var(--c-10);

  --serif-d: 'Fraunces', Georgia, serif;
  --serif-b: 'Fraunces', Georgia, serif;
  --sans:    'IBM Plex Sans', system-ui, sans-serif;
  --mono:    'Spline Sans Mono', ui-monospace, monospace;

  --pad-x:          clamp(20px, 4vw, 56px);
  --rhythm:         1;
  --headline-scale: 1;
  --max-w:          960px;
  --tint-alpha:     0.10;

  /* PAGE EFFECTS — driven by the Effects panel */
  --shadow-alpha:     0.40;
  --shadow-blur:      30px;
  --shine-alpha:      0.00;
  --slot-alpha:       0.70;
  --bg-pattern-alpha: 0.00;

  /* EDITOR THEME — hardcoded; the popup chrome never reacts to the
     page palette. See CONTRACT 5. */
  --e-bg:       #1A1916;
  --e-input-bg: #131210;
  --e-fg:       #ECE5D2;
  --e-fg-soft:  #9C9583;
  --e-rule:     #3F3C33;
  --e-accent:   #E8B23A;
  --e-mono:     'Spline Sans Mono', ui-monospace, monospace;
  --e-display:  'Fraunces', Georgia, serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--serif-b);
  font-size: 16px;
  line-height: 1.55;
}
body { min-height: 100vh; display: flex; flex-direction: column; position: relative; }
a { color: inherit; text-decoration: none; }

/* Background pattern — SVG dots, opacity driven by --bg-pattern-alpha */
.bg-pattern {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  pointer-events: none;
  color: var(--ink-soft);
  opacity: var(--bg-pattern-alpha);
}

/* ============================== SLOT (CONTRACT 3) ============================== */
.slot {
  position: relative;
  background: var(--bg-up);
  border: 1px dashed var(--rule);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
/* The "fake picture" — a gradient overlay whose opacity is editable */
.slot::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, var(--c-1), var(--c-3));
  opacity: var(--slot-alpha);
  z-index: 0;
  pointer-events: none;
}
.slot::before {
  content: attr(data-slot-purpose);
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink);
  padding: 4px 10px;
  text-align: center;
  background: rgba(0, 0, 0, 0.55);
  position: relative;
  z-index: 1;
}
/* Per-slot gradients so each fake picture looks distinct */
[data-slot="lead-figure"]::after    { background: linear-gradient(135deg, var(--c-1), var(--c-3)); }
[data-slot="gallery-1"]::after      { background: linear-gradient( 45deg, var(--c-2), var(--c-5)); }
[data-slot="gallery-2"]::after      { background: linear-gradient(135deg, var(--c-3), var(--c-1)); }
[data-slot="gallery-3"]::after      { background: linear-gradient(225deg, var(--c-4), var(--c-2)); }
[data-slot="closing-figure"]::after { background: linear-gradient(315deg, var(--c-4), var(--c-7)); }

/* ============================== HEADER ============================== */
header {
  padding: 18px var(--pad-x);
  border-bottom: 1px solid var(--rule);
  display: flex;
  gap: 32px;
  align-items: baseline;
  max-width: var(--max-w);
  margin: 0 auto;
  width: 100%;
}
.brand {
  font-family: var(--serif-d);
  font-weight: 500;
  font-size: 22px;
  letter-spacing: -0.018em;
  color: var(--ink);
}
nav { display: flex; gap: 24px; }
nav a {
  font-family: var(--mono);
  font-size: 11.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-soft);
  transition: color 0.15s;
}
nav a:hover { color: var(--ink); }

/* ============================== PAGE SECTIONS ============================== */
main {
  flex: 1;
  padding: 0 var(--pad-x);
  max-width: var(--max-w);
  margin: 0 auto;
  width: 100%;
}
section {
  position: relative;
  padding: calc(40px * var(--rhythm)) 0;
}
/* Section tint overlay — uses the section's accent at --tint-alpha */
section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--sec);
  opacity: var(--tint-alpha);
  z-index: -1;
  pointer-events: none;
}

/* The card — a box demonstrating border, shadow, shine */
.card {
  position: relative;
  background: var(--bg-up);
  border: 1px solid var(--rule);
  padding: 28px 28px 32px;
  box-shadow: 0 8px var(--shadow-blur) rgba(0, 0, 0, var(--shadow-alpha));
  overflow: hidden;
}
/* Shine — a top-down white gradient overlay */
.card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    rgba(255, 255, 255, var(--shine-alpha)) 0%,
    transparent 35%
  );
  pointer-events: none;
}
/* keep content above the shine layer */
.card > * { position: relative; z-index: 1; }

.card h2 {
  font-family: var(--serif-d);
  font-weight: 500;
  font-size: calc(clamp(28px, 3.5vw, 40px) * var(--headline-scale));
  letter-spacing: -0.018em;
  color: var(--sec-heading, var(--sec));
  margin-bottom: 18px;
}
.card p { margin-bottom: 18px; max-width: 56ch; }
.card code {
  font-family: var(--mono);
  font-size: 0.85em;
  color: var(--sec);
}
.card ul { list-style: none; }
.card li {
  padding: 12px 0;
  border-bottom: 1px solid var(--rule);
  color: var(--ink-soft);
  display: flex;
  gap: 16px;
}
.card li:last-child { border-bottom: none; }
.card li::before {
  content: '—';
  color: var(--sec);
}
.gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-top: 18px;
}

/* ============================== FOOTER ============================== */
footer {
  padding: 20px var(--pad-x);
  border-top: 1px solid var(--rule);
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--ink-soft);
  font-family: var(--mono);
  font-size: 11px;
  max-width: var(--max-w);
  margin: 0 auto;
  width: 100%;
}

/* ==============================================================================
   EDITOR — popup chrome reads only from --e-* vars. Page palette / fonts /
   effects never reach this region.
   ============================================================================== */
.editor-trigger {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: transparent;
  border: 1px solid var(--e-rule);
  padding: 8px 14px;
  color: var(--e-fg-soft);
  font-family: var(--e-mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
.editor-trigger:hover { border-color: var(--e-accent); color: var(--e-fg); }
.editor-trigger-glyph {
  position: relative;
  width: 14px;
  height: 14px;
  display: inline-block;
}
.editor-trigger-glyph::before,
.editor-trigger-glyph::after {
  content: '';
  position: absolute;
  width: 9px;
  height: 9px;
  background: var(--e-fg-soft);
  transition: background 0.2s;
}
.editor-trigger-glyph::before { top: 0; left: 0; }
.editor-trigger-glyph::after  { top: 3px; left: 3px; opacity: 0.6; }
.editor-trigger:hover .editor-trigger-glyph::before,
.editor-trigger:hover .editor-trigger-glyph::after { background: var(--e-accent); }

.editor-overlay {
  position: fixed;
  inset: 0;
  background: transparent;
  z-index: 998;
  display: none;
}
.editor-overlay.open { display: block; }
.editor-panel {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 380px;
  max-height: 80vh;
  background: var(--e-bg);
  border: 1px solid var(--e-rule);
  z-index: 999;
  display: none;
  flex-direction: column;
  font-family: var(--e-mono);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
}
.editor-panel.open { display: flex; }
.editor-header {
  padding: 14px 18px;
  border-bottom: 1px solid var(--e-rule);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}
.editor-header-title {
  font-family: var(--e-mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--e-fg-soft);
}
.editor-close {
  background: transparent;
  border: none;
  color: var(--e-fg-soft);
  cursor: pointer;
  font-size: 18px;
  padding: 0 4px;
  line-height: 1;
}
.editor-close:hover { color: var(--e-fg); }
.editor-body {
  overflow-y: auto;
  padding: 18px;
  flex: 1;
}
.editor-section { margin-bottom: 24px; }
.editor-section h3 {
  font-family: var(--e-display);
  font-weight: 500;
  font-size: 18px;
  margin-bottom: 12px;
  color: var(--e-fg);
}

.editor-lock {
  width: 14px;
  height: 14px;
  background: transparent;
  border: 1px solid var(--e-fg-soft);
  cursor: pointer;
  padding: 0;
  flex-shrink: 0;
  transition: background 0.15s, border-color 0.15s;
}
.editor-lock:hover { border-color: var(--e-fg); }
.editor-lock.is-locked {
  background: var(--e-fg-soft);
  border-color: var(--e-fg-soft);
}
.editor-lock.is-locked:hover { background: var(--e-fg); border-color: var(--e-fg); }

.editor-grid-palette {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.editor-palette-cell {
  background: var(--e-input-bg);
  border: 1px solid var(--e-rule);
  padding: 8px;
  display: grid;
  grid-template-columns: 26px 1fr;
  grid-template-rows: auto auto;
  gap: 4px 8px;
  align-items: center;
  min-width: 0;
}
.editor-palette-cell.is-empty { opacity: 0.2; }
.editor-palette-cell .swatch {
  grid-row: 1 / 3;
  width: 26px;
  height: 26px;
  background: var(--swatch, transparent);
}
.editor-palette-cell.is-empty .swatch {
  background: transparent;
  border: 1px dashed var(--e-rule);
}
.editor-palette-cell .label {
  grid-column: 2;
  grid-row: 1;
  font-family: var(--e-mono);
  font-size: 9.5px;
  color: var(--e-fg-soft);
  letter-spacing: 0.04em;
  text-transform: uppercase;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  min-width: 0;
}
.editor-palette-cell .controls {
  grid-column: 2;
  grid-row: 2;
  display: flex;
  gap: 4px;
  align-items: center;
  min-width: 0;
}
.editor-palette-cell .controls .editor-input { flex: 1; min-width: 0; }

.editor-input {
  background: var(--e-input-bg);
  border: 1px solid var(--e-rule);
  color: var(--e-fg);
  font-family: var(--e-mono);
  font-size: 10px;
  padding: 6px 4px;
  width: 100%;
  text-align: center;
}
.editor-input:focus { outline: none; border-color: var(--e-accent); }

.editor-label-row {
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: 8px;
  margin-bottom: 8px;
  align-items: center;
}
.editor-label {
  font-family: var(--e-mono);
  font-size: 10px;
  color: var(--e-fg-soft);
  letter-spacing: 0.04em;
}

.editor-section-group { margin-bottom: 14px; }
.editor-section-group-title {
  font-family: var(--e-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--e-fg);
  margin-bottom: 6px;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--e-rule);
}
.editor-section-spot {
  display: grid;
  grid-template-columns: 16px 60px 1fr 14px;
  gap: 6px;
  margin-bottom: 4px;
  align-items: center;
}
.editor-section-spot .swatch {
  width: 16px;
  height: 16px;
  background: var(--swatch, transparent);
}
.editor-section-spot .spot-label {
  font-family: var(--e-mono);
  font-size: 10px;
  color: var(--e-fg-soft);
  letter-spacing: 0.04em;
}

.editor-slot-row {
  display: grid;
  grid-template-columns: 1fr 130px;
  gap: 8px;
  margin-bottom: 8px;
  align-items: center;
}
.editor-slot-row .label {
  font-family: var(--e-mono);
  font-size: 10px;
  color: var(--e-fg-soft);
  letter-spacing: 0.04em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.editor-select {
  background: var(--e-input-bg);
  border: 1px solid var(--e-rule);
  color: var(--e-fg);
  font-family: var(--e-mono);
  font-size: 11px;
  padding: 6px 8px;
  width: 100%;
  cursor: pointer;
}
.editor-slider {
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
  height: 4px;
  background: linear-gradient(
    to right,
    var(--e-accent) 0%,
    var(--e-accent) var(--fill, 50%),
    var(--e-rule) var(--fill, 50%),
    var(--e-rule) 100%
  );
  outline: none;
}
.editor-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 12px;
  height: 12px;
  background: var(--e-accent);
  border-radius: 50%;
  cursor: pointer;
}
.editor-slider::-moz-range-thumb {
  width: 12px;
  height: 12px;
  background: var(--e-accent);
  border-radius: 50%;
  cursor: pointer;
  border: none;
}

.editor-button {
  background: transparent;
  border: 1px solid var(--e-rule);
  color: var(--e-fg-soft);
  font-family: var(--e-mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 8px 12px;
  cursor: pointer;
  width: 100%;
  margin-top: 6px;
  transition: border-color 0.2s, color 0.2s;
}
.editor-button:hover { border-color: var(--e-accent); color: var(--e-fg); }
.editor-actions { display: flex; flex-direction: column; gap: 6px; }

/* ============================== RESPONSIVE ============================== */
@media (max-width: 680px) {
  header { flex-direction: column; align-items: flex-start; gap: 12px; }
  nav { flex-wrap: wrap; gap: 16px; }
  .gallery { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<svg class="bg-pattern" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <pattern id="bg-dots" width="24" height="24" patternUnits="userSpaceOnUse">
      <circle cx="12" cy="12" r="0.9" fill="currentColor"/>
    </pattern>
  </defs>
  <rect width="100%" height="100%" fill="url(#bg-dots)"/>
</svg>

<header>
  <div class="brand">mudlark.</div>
  <nav>
    <a href="#lead">Lead</a>
    <a href="#items">Items</a>
    <a href="#gallery">Gallery</a>
    <a href="#close">Closing</a>
  </nav>
</header>

<main>

  <section id="lead" data-section="lead" data-section-label="Lead"
           style="--sec: #E8B23A; --sec-heading: #E8B23A;">
    <div class="card">
      <h2>Lead section</h2>
      <p>The card wrapping this content is what the Effects panel acts on — background, border, shadow (opacity + blur), and a top-down shine gradient.</p>
      <div class="slot" data-slot="lead-figure" data-slot-purpose="Lead figure" style="aspect-ratio: 5/4;"></div>
    </div>
  </section>

  <section id="items" data-section="items" data-section-label="Items"
           style="--sec: #DD5E2C; --sec-heading: #DD5E2C;">
    <div class="card">
      <h2>Items section</h2>
      <p>The bullet dashes pick up the section accent. The faint tinted backdrop you see behind the card is each section's accent at <code>--tint-alpha</code>.</p>
      <ul>
        <li>First item</li>
        <li>Second item</li>
        <li>Third item</li>
      </ul>
    </div>
  </section>

  <section id="gallery" data-section="gallery" data-section-label="Gallery"
           style="--sec: #2EA39C; --sec-heading: #2EA39C;">
    <div class="card">
      <h2>Gallery section</h2>
      <p>Slot fills act as fake pictures. The Picture slider in the Effects panel fades them in and out.</p>
      <div class="gallery">
        <div class="slot" data-slot="gallery-1" data-slot-purpose="Gallery tile 1" style="aspect-ratio: 1/1;"></div>
        <div class="slot" data-slot="gallery-2" data-slot-purpose="Gallery tile 2" style="aspect-ratio: 1/1;"></div>
        <div class="slot" data-slot="gallery-3" data-slot-purpose="Gallery tile 3" style="aspect-ratio: 1/1;"></div>
      </div>
    </div>
  </section>

  <section id="close" data-section="close" data-section-label="Closing"
           style="--sec: #4F95CC; --sec-heading: #4F95CC;">
    <div class="card">
      <h2>Closing section</h2>
      <p>The background pattern (small dots) sits behind every section. The BG pattern slider in Effects fades it in.</p>
      <div class="slot" data-slot="closing-figure" data-slot-purpose="Closing figure" style="min-height: 240px;"></div>
    </div>
  </section>

</main>

<footer>
  <span>Test page — exercises every popup feature</span>
  <button class="editor-trigger" type="button" aria-label="Open editor">
    <span class="editor-trigger-glyph" aria-hidden="true"></span>
    <span class="editor-trigger-label">Editor</span>
  </button>
</footer>

<!-- ============================== EDITOR POPUP ============================== -->
<div class="editor-overlay" id="editor-overlay"></div>
<div class="editor-panel" id="editor-panel" role="dialog" aria-label="Page editor">
  <div class="editor-header">
    <div class="editor-header-title">Editor — _popup.html</div>
    <button class="editor-close" id="editor-close" type="button" aria-label="Close">×</button>
  </div>
  <div class="editor-body">

    <div class="editor-section">
      <h3>Palette</h3>
      <div class="editor-grid-palette" id="editor-palette"></div>
      <button class="editor-button" id="editor-randomize" type="button">Randomize</button>
      <div class="editor-label-row" style="margin-top: 12px;">
        <span class="editor-label">Tint alpha</span>
        <input type="range" min="0" max="30" step="1" value="10" class="editor-slider" id="editor-tint-alpha">
      </div>
    </div>

    <div class="editor-section">
      <h3>Sections</h3>
      <div id="editor-sections"></div>
    </div>

    <div class="editor-section">
      <h3>Slots</h3>
      <div id="editor-slots"></div>
    </div>

    <div class="editor-section">
      <h3>Fonts</h3>
      <div id="editor-fonts"></div>
    </div>

    <div class="editor-section">
      <h3>Rhythm</h3>
      <div class="editor-label-row">
        <span class="editor-label">Vertical</span>
