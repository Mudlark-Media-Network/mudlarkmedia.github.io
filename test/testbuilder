    "bg": "#131210", "bgUp": "#1A1916", "bgSurf": "#1F1D19", "bgElev": "#26241E",
    "rule": "#2A2823", "ruleOn": "#3F3C33",
    "ink": "#ECE5D2", "inkSoft": "#9C9583", "inkMute": "#6A6353"
  },
  "fonts": {
    "display": { "family": "Fraunces", "source": "google" },
    "body":    { "family": "Source Serif 4", "source": "google" },
    "sans":    { "family": "IBM Plex Sans", "source": "google" },
    "mono":    { "family": "IBM Plex Mono", "source": "google" }
  },
  "rhythm": {
    "padX": "clamp(20px, 4vw, 56px)",
    "vertical": 1,
    "headlineScale": 1
  },
  "sections": [
    { "id": "lead",               "label": "Lead",                  "accent": "c5" },
    { "id": "ledger",             "label": "Investigation Ledger",  "accent": "c2" },
    { "id": "articles",           "label": "Articles",              "accent": "c2" },
    { "id": "psych",              "label": "Psychological Warfare", "accent": "c5" },
    { "id": "duo-opsec-network",  "label": "OpSec & Network",       "accent": "c3" },
    { "id": "media",              "label": "Media",                 "accent": "c4" },
    { "id": "duo-cited-map",      "label": "Bibliography & Mind Map", "accent": "c6" },
    { "id": "contact",            "label": "Contact",               "accent": "c3" }
  ],
  "slots": [
    { "id": "lead-figure",        "purpose": "Lead figure — document map composite" },
    { "id": "case-013-fig",       "purpose": "Phrase frequency map — case 013" },
    { "id": "article-feature-fig","purpose": "Featured article figure" },
    { "id": "psych-feature-fig",  "purpose": "Psych feature figure — pattern map" },
    { "id": "media-music-art",    "purpose": "Music tile — LP rings graphic" },
    { "id": "media-video-art",    "purpose": "Video tile — play graphic" },
    { "id": "media-audio-art",    "purpose": "Audio tile — waveform graphic" },
    { "id": "media-visual-art",   "purpose": "Visual tile — color block composition" },
    { "id": "mindmap-graph",      "purpose": "Mind map — case 014 entity graph" }
  ]
}
</script>

<script>
(function() {
  const STATE_EL = document.getElementById('builder-state');
  const state = JSON.parse(STATE_EL.textContent);
  const DEFAULTS = JSON.parse(JSON.stringify(state));

  const PALETTE_KEYS = ['c1','c2','c3','c4','c5','c6','c7','c8','c9','c10'];
  const SURFACE_KEYS = ['bg','bgUp','bgSurf','bgElev','rule','ruleOn'];
  const INK_KEYS = ['ink','inkSoft','inkMute'];
  const FONT_ROLES = [
    { key: 'display', label: 'Display', cssVar: '--serif-d', fallback: "'Georgia', serif" },
    { key: 'body',    label: 'Body',    cssVar: '--serif-b', fallback: "'Georgia', serif" },
    { key: 'sans',    label: 'Sans',    cssVar: '--sans',    fallback: 'system-ui, sans-serif' },
    { key: 'mono',    label: 'Mono',    cssVar: '--mono',    fallback: 'ui-monospace, monospace' }
  ];

  const KEY_TO_VAR = {
    c1: '--c-1', c2: '--c-2', c3: '--c-3', c4: '--c-4', c5: '--c-5',
    c6: '--c-6', c7: '--c-7', c8: '--c-8', c9: '--c-9', c10: '--c-10',
    bg: '--bg', bgUp: '--bg-up', bgSurf: '--bg-surf', bgElev: '--bg-elev',
    rule: '--rule', ruleOn: '--rule-on',
    ink: '--ink', inkSoft: '--ink-soft', inkMute: '--ink-mute'
  };
  const TINT_VARS = {
    c1: '--t-1', c2: '--t-2', c3: '--t-3', c4: '--t-4', c5: '--t-5',
    c6: '--t-6', c7: '--t-7', c8: '--t-8', c9: '--t-9', c10: '--t-10'
  };

  let manifestCache = null;
  let manifestStatus = 'idle';

  function normHex(v) {
    if (!v) return null;
    v = v.trim().replace(/^#/, '');
    if (/^[0-9a-f]{3}$/i.test(v)) v = v.split('').map(c => c+c).join('');
    if (/^[0-9a-f]{6}$/i.test(v)) return '#' + v.toLowerCase();
    return null;
  }
  function hexToRgba(hex, a) {
    const v = hex.replace('#','');
    const r = parseInt(v.substring(0,2), 16);
    const g = parseInt(v.substring(2,4), 16);
    const b = parseInt(v.substring(4,6), 16);
    return `rgba(${r}, ${g}, ${b}, ${a})`;
  }
  function randomHex() {
    return '#' + Math.floor(Math.random()*0xffffff).toString(16).padStart(6,'0');
  }

  function applyColor(key, hex) {
    const cssVar = KEY_TO_VAR[key];
    if (cssVar) document.documentElement.style.setProperty(cssVar, hex);
    if (TINT_VARS[key]) document.documentElement.style.setProperty(TINT_VARS[key], hexToRgba(hex, 0.07));
    state.palette[key] = hex;
    saveState();
  }
  function saveState() { STATE_EL.textContent = JSON.stringify(state, null, 2); }

  function buildHexInputs(container, keys) {
    container.innerHTML = '';
    keys.forEach(k => {
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'editor-input';
      input.value = state.palette[k];
      input.title = k;
      input.addEventListener('input', () => {
        const h = normHex(input.value);
        if (h) applyColor(k, h);
      });
      input.addEventListener('blur', () => { input.value = state.palette[k]; });
      container.appendChild(input);
    });
  }

  function buildSectionAssign() {
    const wrap = document.getElementById('editor-sections');
    wrap.innerHTML = '';
    state.sections.forEach(sec => {
      const row = document.createElement('div');
      row.className = 'editor-label-row';
      const lbl = document.createElement('span');
      lbl.className = 'editor-label';
      lbl.textContent = sec.label;
      const sel = document.createElement('select');
      sel.className = 'editor-select';
      PALETTE_KEYS.forEach((k, i) => {
        const opt = document.createElement('option');
        opt.value = k;
        opt.textContent = 'Color ' + String(i+1).padStart(2,'0');
        if (k === sec.accent) opt.selected = true;
        sel.appendChild(opt);
      });
      sel.addEventListener('change', () => {
        sec.accent = sel.value;
        const el = document.querySelector(`[data-section="${sec.id}"]`);
        if (el) el.style.setProperty('--sec', `var(${KEY_TO_VAR[sel.value]})`);
        saveState();
      });
      row.appendChild(lbl);
      row.appendChild(sel);
      wrap.appendChild(row);
    });
  }

  function buildFontPickers() {
    const wrap = document.getElementById('editor-fonts');
    wrap.innerHTML = '';
    FONT_ROLES.forEach(role => {
      const row = document.createElement('div');
      row.className = 'editor-label-row';
      const lbl = document.createElement('span');
      lbl.className = 'editor-label';
      lbl.textContent = role.label;
      const sel = document.createElement('select');
      sel.className = 'editor-select';
      sel.dataset.role = role.key;
      const opt = document.createElement('option');
      opt.textContent = state.fonts[role.key].family + (manifestStatus !== 'loaded' ? ' (loading…)' : '');
      sel.appendChild(opt);
      sel.addEventListener('mousedown', loadManifest);
      sel.addEventListener('change', () => {
        const fontName = sel.value;
        if (!manifestCache) return;
        const entry = (manifestCache[role.key] || []).find(f => f.name === fontName);
        if (!entry) return;
        applyFont(role, entry);
      });
      row.appendChild(lbl);
      row.appendChild(sel);
      wrap.appendChild(row);
    });
  }

  function refreshFontDropdowns() {
    const wrap = document.getElementById('editor-fonts');
    if (!wrap || !manifestCache) return;
    wrap.querySelectorAll('select').forEach(sel => {
      const role = sel.dataset.role;
      const current = state.fonts[role].family;
      sel.innerHTML = '';
      const list = manifestCache[role] || [];
      const seen = new Set();
      if (!list.find(f => f.name === current)) {
        const o = document.createElement('option');
        o.value = current; o.textContent = current; o.selected = true;
        sel.appendChild(o); seen.add(current);
      }
      list.forEach(f => {
        if (seen.has(f.name)) return;
        const o = document.createElement('option');
        o.value = f.name; o.textContent = f.name;
        if (f.name === current) o.selected = true;
        sel.appendChild(o);
      });
    });
  }

  function applyFont(role, entry) {
    let styleEl = document.getElementById('editor-font-' + role.key);
    if (!styleEl) {
      styleEl = document.createElement('style');
      styleEl.id = 'editor-font-' + role.key;
      document.head.appendChild(styleEl);
    }
    const faces = (entry.files || []).map(f => `
      @font-face {
        font-family: '${entry.name}';
        src: url('${f.url}') format('woff2');
        font-weight: ${f.weight || 400};
        font-style: ${f.style || 'normal'};
        font-display: swap;
      }
    `).join('\n');
    styleEl.textContent = faces;
    document.documentElement.style.setProperty(role.cssVar, `'${entry.name}', ${role.fallback}`);
    state.fonts[role.key] = { family: entry.name, source: 'github' };
    saveState();
  }

  function loadManifest() {
    if (manifestStatus !== 'idle') return;
    manifestStatus = 'loading';
    const url = state.page.repo.replace(/\/$/, '') + '/raw/main/editor/fonts.json';
    fetch(url)
      .then(r => r.ok ? r.json() : Promise.reject())
      .then(json => {
        manifestCache = json;
        manifestStatus = 'loaded';
        refreshFontDropdowns();
      })
      .catch(() => { manifestStatus = 'failed'; });
  }

  function bindRhythm() {
    const v = document.getElementById('editor-rhythm-v');
    const p = document.getElementById('editor-rhythm-p');
    const h = document.getElementById('editor-rhythm-h');
    v.addEventListener('input', () => {
      document.documentElement.style.setProperty('--rhythm', v.value);
      state.rhythm.vertical = parseFloat(v.value); saveState();
    });
    p.addEventListener('input', () => {
      document.documentElement.style.setProperty('--pad-x', p.value + 'px');
      state.rhythm.padX = p.value + 'px'; saveState();
    });
    h.addEventListener('input', () => {
      document.documentElement.style.setProperty('--headline-scale', h.value);
      state.rhythm.headlineScale = parseFloat(h.value); saveState();
    });
  }

  function exportHtml() {
    const doc = document.documentElement.cloneNode(true);
    const overlay = doc.querySelector('#editor-overlay');
    const panel = doc.querySelector('#editor-panel');
    if (overlay) overlay.classList.remove('open');
    if (panel) panel.classList.remove('open');
    const styleBlock = doc.querySelector('style');
    if (styleBlock) {
      let css = styleBlock.textContent;
      Object.entries(KEY_TO_VAR).forEach(([k, cssVar]) => {
        const re = new RegExp('(' + cssVar + ':\\s*)#[0-9a-fA-F]{3,6}', 'g');
        css = css.replace(re, '$1' + state.palette[k]);
      });
      Object.entries(TINT_VARS).forEach(([k, cssVar]) => {
        const re = new RegExp('(' + cssVar + ':\\s*)rgba\\([^)]*\\)', 'g');
        css = css.replace(re, '$1' + hexToRgba(state.palette[k], 0.07));
      });
      styleBlock.textContent = css;
    }
    const stateScript = doc.querySelector('#builder-state');
    if (stateScript) stateScript.textContent = JSON.stringify(state, null, 2);
    const blob = new Blob(['<!DOCTYPE html>\n' + doc.outerHTML], { type: 'text/html' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = state.page.filename;
    document.body.appendChild(a); a.click(); a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function copyCss() {
    const lines = [':root {'];
    PALETTE_KEYS.forEach(k => lines.push(`  ${KEY_TO_VAR[k]}: ${state.palette[k]};`));
    PALETTE_KEYS.forEach(k => lines.push(`  ${TINT_VARS[k]}: ${hexToRgba(state.palette[k], 0.07)};`));
    [...SURFACE_KEYS, ...INK_KEYS].forEach(k => lines.push(`  ${KEY_TO_VAR[k]}: ${state.palette[k]};`));
    lines.push(`  --pad-x: ${state.rhythm.padX};`);
    lines.push(`  --rhythm: ${state.rhythm.vertical};`);
    lines.push(`  --headline-scale: ${state.rhythm.headlineScale};`);
    lines.push('}');
    navigator.clipboard.writeText(lines.join('\n')).catch(() => {});
  }

  function resetAll() {
    Object.assign(state.palette, DEFAULTS.palette);
    Object.assign(state.rhythm, DEFAULTS.rhythm);
    state.sections.forEach((s, i) => s.accent = DEFAULTS.sections[i].accent);
    state.fonts = JSON.parse(JSON.stringify(DEFAULTS.fonts));
    PALETTE_KEYS.forEach(k => applyColor(k, state.palette[k]));
    [...SURFACE_KEYS, ...INK_KEYS].forEach(k => {
      document.documentElement.style.setProperty(KEY_TO_VAR[k], state.palette[k]);
    });
    state.sections.forEach(sec => {
      const el = document.querySelector(`[data-section="${sec.id}"]`);
      if (el) el.style.setProperty('--sec', `var(${KEY_TO_VAR[sec.accent]})`);
    });
    document.documentElement.style.setProperty('--rhythm', state.rhythm.vertical);
    document.documentElement.style.setProperty('--pad-x', state.rhythm.padX);
    document.documentElement.style.setProperty('--headline-scale', state.rhythm.headlineScale);
    buildHexInputs(document.getElementById('editor-palette'), PALETTE_KEYS);
    buildHexInputs(document.getElementById('editor-surfaces'), SURFACE_KEYS);
    buildHexInputs(document.getElementById('editor-inks'), INK_KEYS);
    buildSectionAssign();
    saveState();
  }

  const trigger = document.querySelector('.editor-trigger');
  const panel = document.getElementById('editor-panel');
  const overlay = document.getElementById('editor-overlay');
  const closeBtn = document.getElementById('editor-close');

  function openPanel() { panel.classList.add('open'); overlay.classList.add('open'); loadManifest(); }
  function closePanel() { panel.classList.remove('open'); overlay.classList.remove('open'); }
  trigger.addEventListener('click', openPanel);
  closeBtn.addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closePanel(); });

  buildHexInputs(document.getElementById('editor-palette'), PALETTE_KEYS);
  buildHexInputs(document.getElementById('editor-surfaces'), SURFACE_KEYS);
  buildHexInputs(document.getElementById('editor-inks'), INK_KEYS);
  buildSectionAssign();
  buildFontPickers();
  bindRhythm();

  document.getElementById('editor-randomize').addEventListener('click', () => {
    PALETTE_KEYS.forEach(k => applyColor(k, randomHex()));
    buildHexInputs(document.getElementById('editor-palette'), PALETTE_KEYS);
  });
  document.getElementById('editor-export').addEventListener('click', exportHtml);
  document.getElementById('editor-copy').addEventListener('click', copyCss);
  document.getElementById('editor-reset').addEventListener('click', resetAll);
})();
</script>

</body>
