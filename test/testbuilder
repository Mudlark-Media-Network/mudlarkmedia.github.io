<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mudlark Media Network</title>
<meta name="description" content="A volunteer network for survivor voices and the information institutions would rather bury. Zero-fund. Entirely public.">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23131210'/%3E%3Ccircle cx='16' cy='16' r='6' fill='%23DD5E2C'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,400i&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap">

<style>
:root {
  /* palette — 10 working colors, hex */
  --c-1:  #E8B23A;  --c-2:  #DD5E2C;  --c-3:  #2EA39C;  --c-4:  #4F95CC;  --c-5:  #CC6094;
  --c-6:  #6CB855;  --c-7:  #B788D9;  --c-8:  #E89A6B;  --c-9:  #8FB94A;  --c-10: #D94865;

  /* palette tints — rgba, ~7% opacity of the matching --c-N */
  --t-1:  rgba(232, 178, 58, 0.07);  --t-2:  rgba(221, 94, 44, 0.07);  --t-3:  rgba(46, 163, 156, 0.07);  --t-4:  rgba(79, 149, 204, 0.07);  --t-5:  rgba(204, 96, 148, 0.07);
  --t-6:  rgba(108, 184, 85, 0.07);  --t-7:  rgba(183, 136, 217, 0.07); --t-8:  rgba(232, 154, 107, 0.07); --t-9:  rgba(143, 185, 74, 0.07); --t-10: rgba(217, 72, 101, 0.07);

  /* surfaces — near-neutral dark, very low saturation */
  --bg:      #131210;
  --bg-up:   #1A1916;
  --bg-surf: #1F1D19;
  --bg-elev: #26241E;
  --rule:    #2A2823;
  --rule-on: #3F3C33;

  /* ink */
  --ink:      #ECE5D2;
  --ink-soft: #9C9583;
  --ink-mute: #6A6353;

  /* fonts — four roles, with fallbacks */
  --serif-d: 'Fraunces', 'Georgia', serif;
  --serif-b: 'Source Serif 4', 'Georgia', serif;
  --sans:    'IBM Plex Sans', system-ui, sans-serif;
  --mono:    'IBM Plex Mono', ui-monospace, monospace;

  /* rhythm */
  --pad-x:          clamp(20px, 4vw, 56px);
  --rhythm:         1;
  --headline-scale: 1;
  --max-w:          1360px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--serif-b);
  font-size: 16px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
  font-feature-settings: 'kern', 'liga';
}
body { min-height: 100vh; display: flex; flex-direction: column; }
a { color: inherit; text-decoration: none; }
::selection { background: var(--c-1); color: var(--bg); }

/* ============================== SLOT (CONTRACT 3) ============================== */
.slot {
  position: relative;
  background: var(--bg-surf);
  border: 1px dashed var(--rule-on);
  display: flex;
  align-items: center;
  justify-content: center;
}
.slot::before {
  content: attr(data-slot-purpose);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-mute);
  padding: 0 12px;
  text-align: center;
}

/* ============================== TOP STRIP ============================== */
.topstrip {
  padding: 10px var(--pad-x);
  font-family: var(--mono);
  font-size: 11.5px;
  color: var(--ink-soft);
  display: flex;
  gap: 28px;
  flex-wrap: wrap;
  font-variant-numeric: tabular-nums;
}
.topstrip a {
  color: var(--ink-soft);
  border-bottom: 1px dotted var(--rule-on);
  padding-bottom: 1px;
  transition: color 0.15s, border-color 0.15s;
}
.topstrip a:hover { color: var(--c-1); border-bottom-color: var(--c-1); }
.topstrip .dot {
  display: inline-block;
  width: 7px; height: 7px;
  background: var(--c-6);
  border-radius: 50%;
  margin-right: 8px;
  vertical-align: 1px;
  box-shadow: 0 0 10px rgba(108, 184, 85, 0.5);
  animation: pulse 2.6s ease-in-out infinite;
}
@keyframes pulse { 0%, 100% { opacity: 0.55 } 50% { opacity: 1 } }

/* ============================== MASTHEAD ============================== */
.masthead-row {
  padding: 14px var(--pad-x) 36px;
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 56px;
  align-items: end;
}
.wordmark { display: inline-block; line-height: 1; color: var(--ink); }
.wordmark .name {
  font-family: var(--serif-d);
  font-weight: 600;
  font-size: calc(56px * var(--headline-scale));
  letter-spacing: -0.018em;
  font-variation-settings: 'opsz' 144, 'SOFT' 50;
  display: block;
}
.wordmark .name .stop { color: var(--c-2); }
.wordmark .sub {
  display: block;
  margin-top: 10px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.wordmark .sub em { color: var(--c-1); font-style: normal; }
.strapline {
  font-family: var(--serif-b);
  font-style: italic;
  font-size: 16px;
  line-height: 1.5;
  color: var(--ink-soft);
  max-width: 44ch;
  padding-bottom: 8px;
}
.strapline em { color: var(--c-1); font-style: italic; }
.util {
  display: flex;
  align-items: center;
  gap: 22px;
  padding-bottom: 8px;
}
.util .search {
  display: inline-flex;
  align-items: baseline;
  gap: 8px;
  border-bottom: 1px solid var(--rule-on);
  padding: 4px 2px;
  color: var(--ink-soft);
  transition: border-color 0.15s;
  min-width: 220px;
}
.util .search:focus-within { border-bottom-color: var(--c-1); }
.util .search .g { font-family: var(--serif-b); color: var(--ink-mute); font-size: 14px; }
.util .search input {
  flex: 1; background: transparent; border: none; outline: none;
  color: var(--ink); font: 13px var(--sans); min-width: 0;
}
.util .search input::placeholder { color: var(--ink-mute); }
.util .gh {
  font-family: var(--sans);
  font-size: 13px;
  color: var(--ink);
  border-bottom: 1px solid var(--c-2);
  padding-bottom: 3px;
  transition: color 0.15s;
}
.util .gh:hover { color: var(--c-2); }
.util .gh .arr { color: var(--c-2); margin-left: 4px; }

/* ============================== PRIMARY NAV ============================== */
.nav {
  padding: 18px var(--pad-x);
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
  display: flex;
  flex-wrap: wrap;
  gap: 4px 30px;
  font-family: var(--sans);
  font-size: 14.5px;
}
.nav a {
  display: inline-flex; align-items: baseline; gap: 9px;
  padding: 6px 0; color: var(--ink); transition: color 0.15s;
}
.nav a::before {
  content: '';
  width: 7px; height: 7px;
  border-radius: 50%;
  transform: translateY(-2px);
  transition: transform 0.15s;
  flex-shrink: 0;
}
.nav a:hover::before { transform: translateY(-2px) scale(1.4); }
.nav a.n-1::before { background: var(--c-1); }
.nav a.n-2::before { background: var(--c-2); }
.nav a.n-3::before { background: var(--c-3); }
.nav a.n-4::before { background: var(--c-5); }
.nav a.n-5::before { background: var(--c-4); }
.nav a.n-6::before { background: var(--c-6); }
.nav a.n-7::before { background: var(--ink-soft); }
.nav a.n-1:hover { text-decoration: underline; text-decoration-color: var(--c-1); text-underline-offset: 5px; }
.nav a.n-2:hover { text-decoration: underline; text-decoration-color: var(--c-2); text-underline-offset: 5px; }
.nav a.n-3:hover { text-decoration: underline; text-decoration-color: var(--c-3); text-underline-offset: 5px; }
.nav a.n-4:hover { text-decoration: underline; text-decoration-color: var(--c-5); text-underline-offset: 5px; }
.nav a.n-5:hover { text-decoration: underline; text-decoration-color: var(--c-4); text-underline-offset: 5px; }
.nav a.n-6:hover { text-decoration: underline; text-decoration-color: var(--c-6); text-underline-offset: 5px; }
.nav a.n-7:hover { text-decoration: underline; text-decoration-color: var(--ink-soft); text-underline-offset: 5px; }

/* ============================== SHARED RHYTHM ============================== */
main { flex: 1; padding: 0 var(--pad-x) 96px; }
.wrap { max-width: var(--max-w); margin: 0 auto; }

.sec-head {
  display: flex; align-items: baseline;
  gap: 18px;
  border-bottom: 1px solid var(--rule);
  padding-bottom: 16px;
  margin: calc(64px * var(--rhythm)) 0 calc(32px * var(--rhythm));
}
.sec-head h2 {
  font-family: var(--serif-d);
  font-weight: 500;
  font-variation-settings: 'opsz' 60, 'SOFT' 50;
  font-size: calc(clamp(28px, 3.2vw, 40px) * var(--headline-scale));
  letter-spacing: -0.018em;
  line-height: 1;
  flex-shrink: 0;
  color: var(--sec);
}
.sec-head .count {
  font-family: var(--mono);
  font-size: 11.5px;
  color: var(--ink-mute);
  letter-spacing: 0.04em;
  font-variant-numeric: tabular-nums;
}
.sec-head .grow { flex: 1; }
.sec-head .all {
  font-family: var(--sans);
  font-size: 13px;
  color: var(--ink);
  border-bottom: 1px solid var(--rule-on);
  padding-bottom: 2px;
  transition: color 0.15s, border-color 0.15s;
}
.sec-head .all:hover { color: var(--sec); border-bottom-color: var(--sec); }

/* ============================== LEAD ============================== */
section[data-section="lead"] { padding-top: 48px; }
.lead-inner {
  display: grid;
  grid-template-columns: 1.1fr 1fr;
  gap: 56px;
  align-items: start;
}
.lead-fig-wrap { position: relative; }
.lead-fig-wrap .slot { aspect-ratio: 5/4; }
.lead-fig-wrap .stamp {
  position: absolute; top: 12px; left: 12px; z-index: 2;
  font-family: var(--mono); font-size: 10.5px;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--sec);
  padding: 4px 8px;
  background: rgba(19, 18, 16, 0.7);
}
.lead-fig-wrap .cap {
  position: absolute; bottom: 12px; left: 12px; right: 12px; z-index: 2;
  display: flex; justify-content: space-between;
  font-family: var(--mono); font-size: 10.5px;
  color: var(--ink-soft); letter-spacing: 0.05em;
  text-transform: uppercase;
  background: rgba(19, 18, 16, 0.7);
  padding: 4px 8px;
}
.lead-text { padding-top: 6px; }
.lead-kicker {
  font-family: var(--mono); font-size: 11.5px;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--sec);
  margin-bottom: 20px;
}
.lead-kicker .sep { color: var(--ink-mute); margin: 0 10px; }
.lead-kicker .id { color: var(--ink-soft); }
.lead-head {
  font-family: var(--serif-d);
  font-weight: 500;
  font-variation-settings: 'opsz' 144, 'SOFT' 30;
  font-size: calc(clamp(36px, 4.6vw, 64px) * var(--headline-scale));
  line-height: 0.98;
  letter-spacing: -0.022em;
  margin-bottom: 22px;
  max-width: 16ch;
}
.lead-head em {
  font-style: italic;
  color: var(--c-2);
  font-variation-settings: 'opsz' 144, 'SOFT' 100;
}
.lead-deck {
  font-family: var(--serif-b);
  font-size: 17.5px;
  line-height: 1.5;
  color: var(--ink);
  max-width: 50ch;
  margin-bottom: 22px;
}
.lead-meta {
  font-family: var(--sans);
  font-size: 13px;
  color: var(--ink-soft);
  margin-bottom: 22px;
}
.lead-meta .who { color: var(--ink); }
.lead-meta .sep { color: var(--ink-mute); margin: 0 8px; }
.lead-tags {
  display: flex; gap: 18px; flex-wrap: wrap;
  font-family: var(--mono); font-size: 11px;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--ink-soft); margin-bottom: 24px;
}
.lead-tags span::before { content: '['; margin-right: 2px; color: var(--sec); }
.lead-tags span::after  { content: ']'; margin-left: 2px; color: var(--sec); }
.lead-go {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--sans); font-size: 14px; font-weight: 500;
  padding: 12px 22px; background: var(--ink); color: var(--bg);
  transition: background 0.15s;
}
.lead-go:hover { background: var(--sec); }
.lead-go .arr { font-family: var(--mono); font-size: 15px; }

/* ============================== INVESTIGATION LEDGER (distinctive move) ============================== */
/* Vertical numbered case-file ledger on the left, one expanded case on the right.
   Right side has one small figure slot embedded mid-prose. */
.ledger-grid {
  display: grid;
  grid-template-columns: 0.55fr 1fr;
  gap: 56px;
  align-items: start;
}
.ledger-list { display: flex; flex-direction: column; border-top: 1px solid var(--rule); }
.ledger-item {
  display: grid;
  grid-template-columns: 36px 1fr auto;
  gap: 14px;
  padding: 18px 0;
  border-bottom: 1px solid var(--rule);
  align-items: baseline;
  transition: padding-left 0.18s;
  cursor: pointer;
}
.ledger-item:hover { padding-left: 6px; }
.ledger-item.is-open { padding-left: 6px; background: linear-gradient(90deg, var(--lt), transparent 40%); }
.ledger-item .ln {
  font-family: var(--mono); font-size: 12px;
  color: var(--lc); font-variant-numeric: tabular-nums;
  letter-spacing: 0.04em;
}
.ledger-item .body h4 {
  font-family: var(--serif-d); font-weight: 500;
  font-size: 16px; line-height: 1.25;
  font-variation-settings: 'opsz' 30;
  color: var(--ink); margin-bottom: 4px;
  transition: color 0.15s;
}
.ledger-item:hover .body h4,
.ledger-item.is-open .body h4 { color: var(--lc); }
.ledger-item .body p {
  font-family: var(--mono); font-size: 10.5px;
  color: var(--ink-mute); letter-spacing: 0.04em;
}
.ledger-item .dt {
  font-family: var(--mono); font-size: 10.5px;
  color: var(--ink-mute); letter-spacing: 0.04em;
  font-variant-numeric: tabular-nums;
  white-space: nowrap;
}

/* expanded case — right column */
.case-expand .kicker {
  font-family: var(--mono); font-size: 11.5px;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--sec);
  margin-bottom: 16px;
  display: flex; align-items: center; gap: 12px;
}
.case-expand .kicker .id { color: var(--ink-soft); }
.case-expand .kicker .sep { color: var(--ink-mute); }
.case-expand h3 {
  font-family: var(--serif-d); font-weight: 500;
  font-size: clamp(32px, 3.6vw, 48px); line-height: 1;
  letter-spacing: -0.02em;
  margin-bottom: 22px;
  font-variation-settings: 'opsz' 96, 'SOFT' 30;
}
.case-expand h3 em { font-style: italic; color: var(--sec); }
.case-expand .deck {
  font-family: var(--serif-b);
  font-size: 16.5px; line-height: 1.55;
  color: var(--ink-soft);
  margin-bottom: 22px;
  max-width: 60ch;
}
/* embedded mid-prose slot — small, inline, not a hero */
.case-expand .inline-fig {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: 22px;
  margin: 22px 0;
  align-items: start;
}
.case-expand .inline-fig .slot { aspect-ratio: 4/3; }
.case-expand .inline-fig .stamp {
  font-family: var(--mono); font-size: 10.5px;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--sec);
  margin-bottom: 8px;
  display: block;
}
.case-expand .inline-fig p {
  font-family: var(--serif-b); font-size: 14.5px;
  line-height: 1.55; color: var(--ink-soft);
  padding-top: 4px;
}
.case-expand .meta {
  font-family: var(--mono); font-size: 11px;
  color: var(--ink-mute); letter-spacing: 0.04em;
  margin-bottom: 18px;
}
.case-expand .meta b { color: var(--ink-soft); font-weight: 400; }
.case-expand .read {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--sans); font-size: 13px; font-weight: 500;
  padding: 10px 18px; background: transparent; color: var(--ink);
  border: 1px solid var(--rule-on);
  transition: border-color 0.15s, color 0.15s;
}
.case-expand .read:hover { border-color: var(--sec); color: var(--sec); }

/* ============================== ARTICLES (1 slot in row) ============================== */
.articles {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}
.a-card {
  display: flex; flex-direction: column; gap: 12px;
  padding-top: 14px; position: relative;
}
.a-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0;
  height: 2px; background: var(--sec);
}
.a-kicker {
  font-family: var(--mono); font-size: 10.5px;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--sec);
}
.a-card .a-fig { aspect-ratio: 4/5; margin-bottom: 4px; }
.a-card .a-fig .slot { width: 100%; height: 100%; }
.a-head {
  font-family: var(--serif-d); font-weight: 500;
  font-size: 22px; line-height: 1.12; letter-spacing: -0.012em;
  font-variation-settings: 'opsz' 36;
  color: var(--ink);
  transition: color 0.15s;
}
.a-card:hover .a-head { color: var(--sec); }
.a-deck {
  font-family: var(--serif-b); font-size: 14.5px; line-height: 1.5;
  color: var(--ink-soft);
}
.a-meta {
  font-family: var(--mono); font-size: 10.5px;
  color: var(--ink-mute); letter-spacing: 0.04em;
  margin-top: auto; padding-top: 10px;
}
.a-meta b { color: var(--ink-soft); font-weight: 400; }
.a-card.is-quote::before { background: var(--c-1); }
.a-card.is-quote .a-kicker { color: var(--c-1); }
.a-card.is-quote blockquote {
  font-family: var(--serif-d); font-style: italic; font-weight: 400;
  font-size: 20px; line-height: 1.28; color: var(--ink);
  font-variation-settings: 'opsz' 60, 'SOFT' 100;
}
.a-card.is-quote blockquote em { color: var(--c-1); }

/* ============================== PSYCH (1 feature slot + 4 text items) ============================== */
.psych-grid {
  display: grid;
  grid-template-columns: 1.4fr 1fr;
  gap: 48px;
}
.pw-feature { display: flex; flex-direction: column; gap: 14px; }
.pw-feature .pw-fig-wrap { position: relative; }
.pw-feature .pw-fig-wrap .slot { aspect-ratio: 16/10; }
.pw-feature .pw-fig-wrap .stamp {
  position: absolute; top: 12px; left: 12px; z-index: 2;
  font-family: var(--mono); font-size: 10.5px;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--sec);
  padding: 4px 8px;
  background: rgba(19, 18, 16, 0.7);
}
.pw-feature .kicker {
  font-family: var(--mono); font-size: 11px;
  letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--sec);
}
.pw-feature .head {
  font-family: var(--serif-d); font-weight: 500;
  font-size: clamp(28px, 2.6vw, 36px); line-height: 1.05;
  letter-spacing: -0.018em;
}
.pw-feature .head em { color: var(--sec); font-style: italic; }
.pw-feature .deck {
  font-family: var(--serif-b); font-size: 15.5px;
  line-height: 1.5; color: var(--ink-soft);
}
.pw-feature .meta {
  font-family: var(--mono); font-size: 11px; color: var(--ink-mute);
  letter-spacing: 0.04em;
}
.pw-feature .meta b { color: var(--ink-soft); font-weight: 400; }
.pw-list { display: flex; flex-direction: column; }
.pw-item {
  padding: 18px 0;
  border-bottom: 1px solid var(--rule);
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 16px;
  align-items: baseline;
}
.pw-item:first-child { padding-top: 0; }
.pw-item:last-child { border-bottom: none; }
.pw-item .n {
  font-family: var(--mono); font-size: 13px;
  color: var(--sec); font-variant-numeric: tabular-nums;
  letter-spacing: 0.04em;
}
.pw-item .body h4 {
  font-family: var(--serif-d); font-weight: 500;
  font-size: 17px; line-height: 1.25;
  font-variation-settings: 'opsz' 30;
  margin-bottom: 6px;
  color: var(--ink); transition: color 0.15s;
}
.pw-item:hover .body h4 { color: var(--sec); }
.pw-item .body p {
  font-family: var(--mono); font-size: 10.5px; color: var(--ink-mute);
  letter-spacing: 0.04em;
}
.pw-item .body p b { color: var(--ink-soft); font-weight: 400; }

/* ============================== OPSEC + CONTRIBUTORS (text-only row, 0 slots) ============================== */
.duo {
  display: grid;
  grid-template-columns: 1.15fr 1fr;
  gap: 64px;
}
.opsec-list { display: flex; flex-direction: column; }
.op-item {
  padding: 22px 0;
