<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mudlark popup — test page</title>
<meta name="description" content="A minimal page to exercise every popup feature.">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' fill='%23131210'/%3E%3Ccircle cx='16' cy='16' r='6' fill='%23E8B23A'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500&family=Source+Serif+4:opsz,wght@8..60,400&family=IBM+Plex+Sans:wght@400;500&family=IBM+Plex+Mono:wght@400&display=swap">

<style>
:root {
  /* palette — 5 declared; the popup grid leaves 5 empty cells beside them */
  --c-1: #E8B23A;
  --c-2: #DD5E2C;
  --c-3: #2EA39C;
  --c-4: #4F95CC;
  --c-5: #CC6094;

  /* palette tints — rgba at 7% opacity (see TINT_ALPHA in the script) */
  --t-1: rgba(232, 178, 58, 0.07);
  --t-2: rgba(221,  94, 44, 0.07);
  --t-3: rgba( 46, 163, 156, 0.07);
  --t-4: rgba( 79, 149, 204, 0.07);
  --t-5: rgba(204,  96, 148, 0.07);

  /* ground / surfaces */
  --bg:      #131210;
  --bg-up:   #1A1916;
  --bg-surf: #1F1D19;
  --rule:    #2A2823;
  --rule-on: #3F3C33;

  /* ink */
  --ink:      #ECE5D2;
  --ink-soft: #9C9583;
  --ink-mute: #6A6353;

  /* fonts */
  --serif-d: 'Fraunces', Georgia, serif;
  --serif-b: 'Source Serif 4', Georgia, serif;
  --sans:    'IBM Plex Sans', system-ui, sans-serif;
  --mono:    'IBM Plex Mono', ui-monospace, monospace;

  /* rhythm */
  --pad-x:          clamp(20px, 4vw, 56px);
  --rhythm:         1;
  --headline-scale: 1;
  --max-w:          960px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html {
  background: var(--bg);
  color: var(--ink);
  font-family: var(--serif-b);
  font-size: 16px;
  line-height: 1.55;
}
body { min-height: 100vh; display: flex; flex-direction: column; }
a { color: inherit; text-decoration: none; }

/* ============================== SLOT (CONTRACT 3) ============================== */
.slot {
  position: relative;
  background: var(--bg-surf);
  border: 1px dashed var(--rule-on);
  display: flex;
  align-items: center;
  justify-content: center;
}
.slot::before {
  content: attr(data-slot-purpose);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-mute);
  padding: 0 12px;
  text-align: center;
}

/* ============================== HEADER ============================== */
header {
  padding: 18px var(--pad-x);
  border-bottom: 1px solid var(--rule);
  display: flex;
  gap: 32px;
  align-items: baseline;
  max-width: var(--max-w);
  margin: 0 auto;
  width: 100%;
}
.brand {
  font-family: var(--serif-d);
  font-weight: 500;
  font-size: 22px;
  letter-spacing: -0.018em;
  color: var(--ink);
}
nav { display: flex; gap: 24px; }
nav a {
  font-family: var(--mono);
  font-size: 11.5px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink-soft);
  transition: color 0.15s;
}
nav a:hover { color: var(--ink); }

/* ============================== PAGE SECTIONS ============================== */
main {
  flex: 1;
  padding: 0 var(--pad-x);
  max-width: var(--max-w);
  margin: 0 auto;
  width: 100%;
}
section {
  padding: calc(48px * var(--rhythm)) 0;
  border-bottom: 1px solid var(--rule);
}
section h2 {
  font-family: var(--serif-d);
  font-weight: 500;
  font-size: calc(clamp(28px, 3.5vw, 40px) * var(--headline-scale));
  letter-spacing: -0.018em;
  color: var(--sec);
  margin-bottom: 18px;
}
section p { margin-bottom: 18px; max-width: 56ch; }
section code {
  font-family: var(--mono);
  font-size: 0.85em;
  color: var(--sec);
}
section ul { list-style: none; }
section li {
  padding: 12px 0;
  border-bottom: 1px solid var(--rule);
  color: var(--ink-soft);
  display: flex;
  gap: 16px;
}
section li::before {
  content: '—';
  color: var(--sec);
}
.gallery {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-top: 18px;
}

/* ============================== FOOTER ============================== */
footer {
  padding: 20px var(--pad-x);
  border-top: 1px solid var(--rule);
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--ink-mute);
  font-family: var(--mono);
  font-size: 11px;
  max-width: var(--max-w);
  margin: 0 auto;
  width: 100%;
}

/* ============================== EDITOR TRIGGER (CONTRACT 5) ============================== */
.editor-trigger {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: transparent;
  border: 1px solid var(--rule-on);
  padding: 8px 14px;
  color: var(--ink-soft);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
.editor-trigger:hover { border-color: var(--c-1); color: var(--ink); }
.editor-trigger-glyph {
  position: relative;
  width: 14px;
  height: 14px;
  display: inline-block;
}
.editor-trigger-glyph::before,
.editor-trigger-glyph::after {
  content: '';
  position: absolute;
  width: 9px;
  height: 9px;
  background: var(--ink-soft);
  transition: background 0.2s;
}
.editor-trigger-glyph::before { top: 0; left: 0; }
.editor-trigger-glyph::after  { top: 3px; left: 3px; opacity: 0.6; }
.editor-trigger:hover .editor-trigger-glyph::before,
.editor-trigger:hover .editor-trigger-glyph::after { background: var(--c-1); }

/* ============================== EDITOR PANEL ============================== */
.editor-overlay {
  position: fixed;
  inset: 0;
  background: transparent;
  z-index: 998;
  display: none;
}
.editor-overlay.open { display: block; }
.editor-panel {
  position: fixed;
  bottom: 20px;
  right: 20px;
  width: 340px;
  max-height: 80vh;
  background: var(--bg-up);
  border: 1px solid var(--rule-on);
  z-index: 999;
  display: none;
  flex-direction: column;
  font-family: var(--sans);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
}
.editor-panel.open { display: flex; }
.editor-header {
  padding: 14px 18px;
  border-bottom: 1px solid var(--rule);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}
.editor-header-title {
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink-soft);
}
.editor-close {
  background: transparent;
  border: none;
  color: var(--ink-mute);
  cursor: pointer;
  font-size: 18px;
  padding: 0 4px;
  line-height: 1;
}
.editor-close:hover { color: var(--ink); }
.editor-body {
  overflow-y: auto;
  padding: 18px;
  flex: 1;
}
.editor-section { margin-bottom: 24px; }
.editor-section h3 {
  font-family: var(--serif-d);
  font-weight: 500;
  font-size: 18px;
  margin-bottom: 12px;
  color: var(--ink);
}
.editor-grid-palette {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6px;
}
.editor-cell-empty { /* visual placeholder so the 10-cell grid stays intact */ }
.editor-input {
  background: var(--bg);
  border: 1px solid var(--rule);
  color: var(--ink);
  font-family: var(--mono);
  font-size: 10px;
  padding: 6px 4px;
  width: 100%;
  text-align: center;
}
.editor-input:focus { outline: none; border-color: var(--c-1); }
.editor-label-row {
  display: grid;
  grid-template-columns: 90px 1fr;
  gap: 8px;
  margin-bottom: 8px;
  align-items: center;
}
.editor-label {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--ink-mute);
  letter-spacing: 0.04em;
}

/* at-a-glance row — shows which sections use each palette slot */
.editor-glance {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 4px;
  margin-bottom: 14px;
}
.editor-glance-cell {
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 0;
}
.editor-glance-swatch {
  width: 100%;
  aspect-ratio: 1;
  background: var(--swatch);
}
.editor-glance-cell.is-empty .editor-glance-swatch {
  background: transparent;
  border: 1px dashed var(--rule);
}
.editor-glance-labels {
  font-family: var(--mono);
  font-size: 8px;
  line-height: 1.15;
  color: var(--ink-mute);
  letter-spacing: 0.02em;
  word-break: break-word;
}

/* slot-dimension rows */
.editor-slot-row {
  display: grid;
  grid-template-columns: 1fr 96px;
  gap: 8px;
  margin-bottom: 8px;
  align-items: center;
}
.editor-slot-row .label {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--ink-mute);
  letter-spacing: 0.04em;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.editor-select {
  background: var(--bg);
  border: 1px solid var(--rule);
  color: var(--ink);
  font-family: var(--mono);
  font-size: 11px;
  padding: 6px 8px;
  width: 100%;
  cursor: pointer;
}
.editor-slider {
  width: 100%;
  -webkit-appearance: none;
  appearance: none;
  height: 2px;
  background: var(--rule-on);
  outline: none;
}
.editor-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 12px;
  height: 12px;
  background: var(--c-1);
  border-radius: 50%;
  cursor: pointer;
}
.editor-slider::-moz-range-thumb {
  width: 12px;
  height: 12px;
  background: var(--c-1);
  border-radius: 50%;
  cursor: pointer;
  border: none;
}
.editor-button {
  background: transparent;
  border: 1px solid var(--rule-on);
  color: var(--ink-soft);
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 8px 12px;
  cursor: pointer;
  width: 100%;
  margin-top: 6px;
  transition: border-color 0.2s, color 0.2s;
}
.editor-button:hover { border-color: var(--c-1); color: var(--ink); }
.editor-actions { display: flex; flex-direction: column; gap: 6px; }

/* ============================== REDUCED MOTION ============================== */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}

/* ============================== RESPONSIVE ============================== */
@media (max-width: 680px) {
  header { flex-direction: column; align-items: flex-start; gap: 12px; }
  nav { flex-wrap: wrap; gap: 16px; }
  .gallery { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<header>
  <div class="brand">mudlark.</div>
  <nav>
    <a href="#lead">Lead</a>
    <a href="#items">Items</a>
    <a href="#gallery">Gallery</a>
    <a href="#close">Closing</a>
  </nav>
</header>

<main>

  <section id="lead" data-section="lead" data-section-label="Lead" style="--sec: var(--c-1);">
    <h2>Lead section</h2>
    <p>Body type at primary weight. The heading uses <code>var(--sec)</code> so its colour matches whichever palette slot the Sections control assigns. Hex inputs are live — type a new value into Palette and watch this heading change.</p>
    <div class="slot" data-slot="lead-figure" data-slot-purpose="Lead figure" style="aspect-ratio: 5/4;"></div>
  </section>

  <section id="items" data-section="items" data-section-label="Items" style="--sec: var(--c-2);">
    <h2>Items section</h2>
    <p>A text-only section — no slots. The bullet dashes pick up the section accent.</p>
    <ul>
      <li>First item</li>
      <li>Second item</li>
      <li>Third item</li>
    </ul>
  </section>

  <section id="gallery" data-section="gallery" data-section-label="Gallery" style="--sec: var(--c-3);">
    <h2>Gallery section</h2>
    <p>Three slots in a row to test the slot-size control. Try <code>1/1</code>, <code>5/4</code>, <code>16/9</code>, or <code>240px</code>.</p>
    <div class="gallery">
      <div class="slot" data-slot="gallery-1" data-slot-purpose="Gallery tile 1" style="aspect-ratio: 1/1;"></div>
      <div class="slot" data-slot="gallery-2" data-slot-purpose="Gallery tile 2" style="aspect-ratio: 1/1;"></div>
      <div class="slot" data-slot="gallery-3" data-slot-purpose="Gallery tile 3" style="aspect-ratio: 1/1;"></div>
    </div>
  </section>

  <section id="close" data-section="close" data-section-label="Closing" style="--sec: var(--c-4);">
    <h2>Closing section</h2>
    <p>A wide slot sized via <code>min-height</code> rather than aspect-ratio.</p>
    <div class="slot" data-slot="closing-figure" data-slot-purpose="Closing figure" style="min-height: 240px;"></div>
  </section>

</main>

<footer>
  <span>Test page — exercises every popup feature</span>
  <button class="editor-trigger" type="button" aria-label="Open editor">
    <span class="editor-trigger-glyph" aria-hidden="true"></span>
    <span class="editor-trigger-label">Editor</span>
  </button>
</footer>

<!-- ============================== EDITOR POPUP ============================== -->
<div class="editor-overlay" id="editor-overlay"></div>
<div class="editor-panel" id="editor-panel" role="dialog" aria-label="Page editor">
  <div class="editor-header">
    <div class="editor-header-title">Editor — _popup.html</div>
    <button class="editor-close" id="editor-close" type="button" aria-label="Close">×</button>
  </div>
  <div class="editor-body">

    <div class="editor-section">
      <h3>Palette</h3>
      <div class="editor-grid-palette" id="editor-palette"></div>
      <button class="editor-button" id="editor-randomize" type="button">Randomize</button>
    </div>

    <div class="editor-section">
      <h3>Ground &amp; Ink</h3>
      <div id="editor-surfaces"></div>
      <div id="editor-inks" style="margin-top: 6px;"></div>
    </div>

    <div class="editor-section">
      <h3>Sections</h3>
      <div class="editor-glance" id="editor-glance"></div>
      <div id="editor-sections"></div>
    </div>

    <div class="editor-section">
      <h3>Slots</h3>
      <div id="editor-slots"></div>
    </div>

    <div class="editor-section">
      <h3>Fonts</h3>
      <div id="editor-fonts"></div>
    </div>

    <div class="editor-section">
      <h3>Rhythm</h3>
      <div class="editor-label-row">
        <span class="editor-label">Vertical</span>
        <input type="range" min="0.7" max="1.5" step="0.05" value="1" class="editor-slider" id="editor-rhythm-v">
      </div>
      <div class="editor-label-row">
        <span class="editor-label">Padding</span>
        <input type="range" min="12" max="80" step="2" value="40" class="editor-slider" id="editor-rhythm-p">
      </div>
      <div class="editor-label-row">
        <span class="editor-label">Headline</span>
        <input type="range" min="0.85" max="1.2" step="0.01" value="1" class="editor-slider" id="editor-rhythm-h">
      </div>
    </div>

    <div class="editor-section">
      <h3>Actions</h3>
      <div class="editor-actions">
        <button class="editor-button" id="editor-export" type="button">Export HTML</button>
        <button class="editor-button" id="editor-copy"   type="button">Copy CSS</button>
        <button class="editor-button" id="editor-reset"  type="button">Reset</button>
      </div>
    </div>

  </div>
</div>

<script type="application/json" id="builder-state">
{
  "schema": 2,
  "page": {
    "id": "_popup",
    "title": "Mudlark popup — test page",
    "filename": "_popup.html",
    "siblings": [],
    "repo": "https://github.com/Mudlark-Media-Network/mudlarkmedia.github.io"
  },
  "palette": {
    "c1": "#E8B23A",
    "c2": "#DD5E2C",
    "c3": "#2EA39C",
    "c4": "#4F95CC",
    "c5": "#CC6094"
  },
  "surfaces": {
    "bg":     { "var": "--bg",      "value": "#131210" },
    "bgUp":   { "var": "--bg-up",   "value": "#1A1916" },
    "bgSurf": { "var": "--bg-surf", "value": "#1F1D19" },
    "rule":   { "var": "--rule",    "value": "#2A2823" },
    "ruleOn": { "var": "--rule-on", "value": "#3F3C33" }
  },
  "ink": {
    "ink":     { "var": "--ink",      "value": "#ECE5D2" },
    "inkSoft": { "var": "--ink-soft", "value": "#9C9583" },
    "inkMute": { "var": "--ink-mute", "value": "#6A6353" }
  },
  "fonts": {
    "display": { "family": "Fraunces",       "source": "google" },
    "body":    { "family": "Source Serif 4", "source": "google" },
    "sans":    { "family": "IBM Plex Sans",  "source": "google" },
    "mono":    { "family": "IBM Plex Mono",  "source": "google" }
  },
  "rhythm": {
    "padX": "clamp(20px, 4vw, 56px)",
    "vertical": 1,
    "headlineScale": 1
  },
  "sections": [
    { "id": "lead",    "label": "Lead",    "accent": "c1" },
    { "id": "items",   "label": "Items",   "accent": "c2" },
    { "id": "gallery", "label": "Gallery", "accent": "c3" },
    { "id": "close",   "label": "Closing", "accent": "c4" }
  ],
  "slots": [
    { "id": "lead-figure",    "purpose": "Lead figure" },
    { "id": "gallery-1",      "purpose": "Gallery tile 1" },
    { "id": "gallery-2",      "purpose": "Gallery tile 2" },
    { "id": "gallery-3",      "purpose": "Gallery tile 3" },
    { "id": "closing-figure", "purpose": "Closing figure" }
  ]
}
</script>

<script>
(function () {

  // ---------- constants ----------
  const TINT_ALPHA = 0.07; // palette tints use 7% opacity over the ground
  const FONT_ROLES = [
    { key: 'display', label: 'Display', cssVar: '--serif-d', fallback: 'Georgia, serif' },
    { key: 'body',    label: 'Body',    cssVar: '--serif-b', fallback: 'Georgia, serif' },
    { key: 'sans',    label: 'Sans',    cssVar: '--sans',    fallback: 'system-ui, sans-serif' },
    { key: 'mono',    label: 'Mono',    cssVar: '--mono',    fallback: 'ui-monospace, monospace' }
  ];

  // ---------- state ----------
  const STATE_EL = document.getElementById('builder-state');
  let state, DEFAULTS;
  try {
    state = JSON.parse(STATE_EL.textContent);
    DEFAULTS = JSON.parse(JSON.stringify(state));
  } catch (e) {
    console.error('builder-state JSON is invalid:', e);
    return;
  }

  let manifestCache = null;
  let manifestStatus = 'idle';

  // ---------- helpers ----------
  function normHex(v) {
    if (!v) return null;
    v = v.trim().replace(/^#/, '');
    if (/^[0-9a-f]{3}$/i.test(v)) v = v.split('').map(c => c + c).join('');
    if (/^[0-9a-f]{6}$/i.test(v)) return '#' + v.toLowerCase();
    return null;
  }
  function hexToRgba(hex, a) {
    const v = hex.replace('#', '');
    const r = parseInt(v.substring(0, 2), 16);
    const g = parseInt(v.substring(2, 4), 16);
    const b = parseInt(v.substring(4, 6), 16);
    return `rgba(${r}, ${g}, ${b}, ${a})`;
  }
  function randomHex() {
    return '#' + Math.floor(Math.random() * 0xffffff).toString(16).padStart(6, '0');
  }
  function paletteCssVar(key)  { return '--c-' + key.slice(1); }
  function paletteTintVar(key) { return '--t-' + key.slice(1); }

  // ---------- builders (render UI from state) ----------
  function buildPaletteInputs() {
    const container = document.getElementById('editor-palette');
    container.innerHTML = '';
    for (let i = 1; i <= 10; i++) {
      const key = 'c' + i;
      if (key in state.palette) {
        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'editor-input';
        input.value = state.palette[key];
        input.title = key;
        input.addEventListener('input', () => {
          const h = normHex(input.value);
          if (h) applyPaletteColor(key, h);
        });
        input.addEventListener('blur', () => { input.value = state.palette[key]; });
        container.appendChild(input);
      } else {
        const empty = document.createElement('div');
        empty.className = 'editor-cell-empty';
        container.appendChild(empty);
      }
    }
  }

  function buildSurfaceInputs(containerId, group) {
    const container = document.getElementById(containerId);
    container.innerHTML = '';
    Object.entries(group).forEach(([key, entry]) => {
      const row = document.createElement('div');
      row.className = 'editor-label-row';
      const lbl = document.createElement('span');
      lbl.className = 'editor-label';
      lbl.textContent = key;
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'editor-input';
      input.value = entry.value;
      input.addEventListener('input', () => {
        const h = normHex(input.value);
        if (h) {
          entry.value = h;
          document.documentElement.style.setProperty(entry.var, h);
        }
      });
      input.addEventListener('blur', () => { input.value = entry.value; });
      row.appendChild(lbl);
      row.appendChild(input);
      container.appendChild(row);
    });
  }

  function buildSectionAssign() {
    const wrap = document.getElementById('editor-sections');
    wrap.innerHTML = '';
    const declared = Object.keys(state.palette);
    state.sections.forEach(sec => {
      const row = document.createElement('div');
      row.className = 'editor-label-row';
      const lbl = document.createElement('span');
      lbl.className = 'editor-label';
      lbl.textContent = sec.label;
      const sel = document.createElement('select');
      sel.className = 'editor-select';
      declared.forEach(k => {
        const opt = document.createElement('option');
        opt.value = k;
        opt.textContent = 'Color ' + String(Number(k.slice(1))).padStart(2, '0');
        if (k === sec.accent) opt.selected = true;
        sel.appendChild(opt);
      });
      const neutralOpt = document.createElement('option');
      neutralOpt.value = 'none';
      neutralOpt.textContent = 'Neutral';
      if (sec.accent === 'none') neutralOpt.selected = true;
      sel.appendChild(neutralOpt);
      sel.addEventListener('change', () => {
        sec.accent = sel.value;
        applySectionAccent(sec);
        renderGlance();
      });
      row.appendChild(lbl);
      row.appendChild(sel);
      wrap.appendChild(row);
    });
  }

  function buildSlots() {
    const wrap = document.getElementById('editor-slots');
    wrap.innerHTML = '';
    state.slots.forEach(slot => {
      const row = document.createElement('div');
      row.className = 'editor-slot-row';
      const lbl = document.createElement('span');
      lbl.className = 'label';
      lbl.textContent = slot.purpose;
      lbl.title = slot.purpose;
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'editor-input';
      input.placeholder = '5/4 or 480px';
      const el = document.querySelector(`[data-slot="${slot.id}"]`);
      if (el) input.value = el.style.aspectRatio || el.style.minHeight || '';
      input.addEventListener('input', () => applySlotSize(slot.id, input.value));
      row.appendChild(lbl);
      row.appendChild(input);
      wrap.appendChild(row);
    });
  }

  function buildFontPickers() {
    const wrap = document.getElementById('editor-fonts');
    wrap.innerHTML = '';
    FONT_ROLES.forEach(role => {
      const row = document.createElement('div');
      row.className = 'editor-label-row';
      const lbl = document.createElement('span');
      lbl.className = 'editor-label';
      lbl.textContent = role.label;
      const sel = document.createElement('select');
      sel.className = 'editor-select';
      sel.dataset.role = role.key;
      renderFontOptions(sel, role);
      sel.addEventListener('mousedown', loadManifest);
      sel.addEventListener('change', () => {
        if (!manifestCache) return;
        const entry = (manifestCache[role.key] || []).find(f => f.name === sel.value);
        if (entry) applyFont(role, entry);
      });
      row.appendChild(lbl);
      row.appendChild(sel);
      wrap.appendChild(row);
    });
  }

  function renderFontOptions(sel, role) {
    sel.innerHTML = '';
    const current = state.fonts[role.key].family;
    const o = document.createElement('option');
    o.value = current;
    o.textContent = current + (manifestStatus === 'loaded' ? '' : ' (loading…)');
    o.selected = true;
    sel.appendChild(o);
    if (manifestCache) {
      (manifestCache[role.key] || []).forEach(f => {
        if (f.name === current) return;
        const opt = document.createElement('option');
        opt.value = f.name;
        opt.textContent = f.name;
        sel.appendChild(opt);
      });
    }
  }

  function renderGlance() {
    const wrap = document.getElementById('editor-glance');
    wrap.innerHTML = '';
    for (let i = 1; i <= 10; i++) {
      const key = 'c' + i;
      const isDeclared = key in state.palette;
      const using = state.sections.filter(s => s.accent === key);
      const cell = document.createElement('div');
      cell.className = 'editor-glance-cell' + (isDeclared ? '' : ' is-empty');
      const sw = document.createElement('div');
      sw.className = 'editor-glance-swatch';
      if (isDeclared) sw.style.setProperty('--swatch', state.palette[key]);
      cell.appendChild(sw);
      const lbl = document.createElement('div');
      lbl.className = 'editor-glance-labels';
      lbl.textContent = using.map(s => s.label).join(', ');
      cell.appendChild(lbl);
      wrap.appendChild(cell);
    }
  }

  // ---------- behaviors (mutate state and the document) ----------
  function applyPaletteColor(key, hex) {
    document.documentElement.style.setProperty(paletteCssVar(key), hex);
    document.documentElement.style.setProperty(paletteTintVar(key), hexToRgba(hex, TINT_ALPHA));
    state.palette[key] = hex;
    renderGlance();
  }

  function applySectionAccent(sec) {
    const el = document.querySelector(`[data-section="${sec.id}"]`);
    if (!el) return;
    if (sec.accent === 'none') {
      el.style.setProperty('--sec', 'var(--ink-soft)');
    } else {
      el.style.setProperty('--sec', 'var(' + paletteCssVar(sec.accent) + ')');
    }
  }

  function applySlotSize(id, value) {
    const el = document.querySelector(`[data-slot="${id}"]`);
    if (!el) return;
    const v = value.trim();
    if (!v) {
      el.style.aspectRatio = '';
      el.style.minHeight = '';
      return;
    }
    if (/^\d+\s*\/\s*\d+$/.test(v)) {
      el.style.aspectRatio = v;
      el.style.minHeight = '';
    } else {
      el.style.minHeight = v;
      el.style.aspectRatio = '';
    }
  }

  function applyFont(role, entry) {
    let styleEl = document.getElementById('editor-font-' + role.key);
    if (!styleEl) {
      styleEl = document.createElement('style');
      styleEl.id = 'editor-font-' + role.key;
      document.head.appendChild(styleEl);
    }
    const faces = (entry.files || []).map(f => `
      @font-face {
        font-family: '${entry.name}';
        src: url('${f.url}') format('woff2');
        font-weight: ${f.weight || 400};
        font-style: ${f.style || 'normal'};
        font-display: swap;
      }
    `).join('\n');
    styleEl.textContent = faces;
    document.documentElement.style.setProperty(role.cssVar, `'${entry.name}', ${role.fallback}`);
    state.fonts[role.key] = { family: entry.name, source: 'github' };
  }

  function loadManifest() {
    if (manifestStatus !== 'idle') return;
    manifestStatus = 'loading';
    const url = state.page.repo.replace(/\/$/, '') + '/raw/main/editor/fonts.json';
    fetch(url)
      .then(r => r.ok ? r.json() : Promise.reject())
      .then(json => {
        manifestCache = json;
        manifestStatus = 'loaded';
        refreshFontDropdowns();
      })
      .catch(() => { manifestStatus = 'failed'; });
  }

  function refreshFontDropdowns() {
    document.querySelectorAll('#editor-fonts select').forEach(sel => {
      const role = FONT_ROLES.find(r => r.key === sel.dataset.role);
      if (role) renderFontOptions(sel, role);
    });
  }

  function bindRhythm() {
    const v = document.getElementById('editor-rhythm-v');
    const p = document.getElementById('editor-rhythm-p');
    const h = document.getElementById('editor-rhythm-h');
    v.addEventListener('input', () => {
      document.documentElement.style.setProperty('--rhythm', v.value);
      state.rhythm.vertical = parseFloat(v.value);
    });
    p.addEventListener('input', () => {
      document.documentElement.style.setProperty('--pad-x', p.value + 'px');
      state.rhythm.padX = p.value + 'px';
    });
    h.addEventListener('input', () => {
      document.documentElement.style.setProperty('--headline-scale', h.value);
      state.rhythm.headlineScale = parseFloat(h.value);
    });
  }

  function exportHtml() {
    const doc = document.documentElement.cloneNode(true);
    doc.querySelector('#editor-overlay')?.classList.remove('open');
    doc.querySelector('#editor-panel')?.classList.remove('open');

    // Bake live values from in-memory state into the cloned <style> block.
    // The popup mutates :root via setProperty at runtime; without this pass
    // the exported file would still carry the original CSS defaults.
    const styleBlock = doc.querySelector('style');
    if (styleBlock) {
      let css = styleBlock.textContent;
      Object.entries(state.palette).forEach(([key, hex]) => {
        const cVar = paletteCssVar(key);
        css = css.replace(new RegExp('(' + cVar + ':\\s*)#[0-9a-fA-F]{3,6}', 'g'), '$1' + hex);
        const tVar = paletteTintVar(key);
        css = css.replace(new RegExp('(' + tVar + ':\\s*)rgba\\([^)]*\\)', 'g'), '$1' + hexToRgba(hex, TINT_ALPHA));
      });
      Object.values(state.surfaces).concat(Object.values(state.ink)).forEach(entry => {
        css = css.replace(new RegExp('(' + entry.var + ':\\s*)#[0-9a-fA-F]{3,6}', 'g'), '$1' + entry.value);
      });
      styleBlock.textContent = css;
    }

    // Sync state blob — only point we re-serialize the in-memory state
    const stateScript = doc.querySelector('#builder-state');
    if (stateScript) stateScript.textContent = JSON.stringify(state, null, 2);

    const blob = new Blob(['<!DOCTYPE html>\n' + doc.outerHTML], { type: 'text/html' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = state.page.filename;
    document.body.appendChild(a);
    a.click();
    a.remove();
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }

  function copyCss() {
    const lines = [':root {'];
    Object.entries(state.palette).forEach(([k, hex]) => {
      lines.push(`  ${paletteCssVar(k)}: ${hex};`);
    });
    Object.entries(state.palette).forEach(([k, hex]) => {
      lines.push(`  ${paletteTintVar(k)}: ${hexToRgba(hex, TINT_ALPHA)};`);
    });
    Object.values(state.surfaces).forEach(e => lines.push(`  ${e.var}: ${e.value};`));
    Object.values(state.ink).forEach(e      => lines.push(`  ${e.var}: ${e.value};`));
    lines.push(`  --pad-x: ${state.rhythm.padX};`);
    lines.push(`  --rhythm: ${state.rhythm.vertical};`);
    lines.push(`  --headline-scale: ${state.rhythm.headlineScale};`);
    lines.push('}');
    navigator.clipboard.writeText(lines.join('\n')).catch(() => {});
  }

  function resetAll() {
    // palette + tints
    Object.entries(DEFAULTS.palette).forEach(([k, v]) => {
      state.palette[k] = v;
      document.documentElement.style.setProperty(paletteCssVar(k), v);
      document.documentElement.style.setProperty(paletteTintVar(k), hexToRgba(v, TINT_ALPHA));
    });
    // surfaces + ink
    ['surfaces', 'ink'].forEach(groupKey => {
      Object.entries(DEFAULTS[groupKey]).forEach(([k, entry]) => {
        state[groupKey][k] = { var: entry.var, value: entry.value };
        document.documentElement.style.setProperty(entry.var, entry.value);
      });
    });
    // rhythm
    Object.assign(state.rhythm, DEFAULTS.rhythm);
    document.documentElement.style.setProperty('--rhythm', state.rhythm.vertical);
    document.documentElement.style.setProperty('--pad-x', state.rhythm.padX);
    document.documentElement.style.setProperty('--headline-scale', state.rhythm.headlineScale);
    // sections
    state.sections.forEach((sec, i) => {
      sec.accent = DEFAULTS.sections[i].accent;
      applySectionAccent(sec);
    });
    // fonts
    state.fonts = JSON.parse(JSON.stringify(DEFAULTS.fonts));
    FONT_ROLES.forEach(role => {
      document.documentElement.style.setProperty(role.cssVar,
        `'${state.fonts[role.key].family}', ${role.fallback}`);
    });
    // slots — clear inline styles so the page's CSS defaults reapply
    state.slots.forEach(slot => {
      const el = document.querySelector(`[data-slot="${slot.id}"]`);
      if (el) { el.style.aspectRatio = ''; el.style.minHeight = ''; }
    });
    // re-render the panel
    buildPaletteInputs();
    buildSurfaceInputs('editor-surfaces', state.surfaces);
    buildSurfaceInputs('editor-inks',     state.ink);
    buildSectionAssign();
    buildSlots();
    refreshFontDropdowns();
    renderGlance();
  }

  // ---------- wiring ----------
  const trigger  = document.querySelector('.editor-trigger');
  const panel    = document.getElementById('editor-panel');
  const overlay  = document.getElementById('editor-overlay');
  const closeBtn = document.getElementById('editor-close');

  let lastFocused = null;

  function openPanel() {
    lastFocused = document.activeElement;
    panel.classList.add('open');
    overlay.classList.add('open');
    loadManifest();
    const firstFocusable = panel.querySelector('button, input, select');
    if (firstFocusable) firstFocusable.focus();
  }
  function closePanel() {
    panel.classList.remove('open');
    overlay.classList.remove('open');
    if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
  }
  function trapFocus(e) {
    if (e.key !== 'Tab' || !panel.classList.contains('open')) return;
    const focusables = panel.querySelectorAll(
      'button, [href], input, select, [tabindex]:not([tabindex="-1"])'
    );
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last  = focusables[focusables.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  trigger.addEventListener('click', openPanel);
  closeBtn.addEventListener('click', closePanel);
  overlay.addEventListener('click', closePanel);
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') closePanel();
    trapFocus(e);
  });

  buildPaletteInputs();
  buildSurfaceInputs('editor-surfaces', state.surfaces);
  buildSurfaceInputs('editor-inks',     state.ink);
  buildSectionAssign();
  buildSlots();
  buildFontPickers();
  bindRhythm();
  renderGlance();

  document.getElementById('editor-randomize').addEventListener('click', () => {
    Object.keys(state.palette).forEach(k => applyPaletteColor(k, randomHex()));
    buildPaletteInputs();
  });
  document.getElementById('editor-export').addEventListener('click', exportHtml);
  document.getElementById('editor-copy').addEventListener('click', copyCss);
  document.getElementById('editor-reset').addEventListener('click', resetAll);

})();
</script>

</body>
</html>
